---
import socials from "../data/socials.json";
import { Icon } from "astro-icon/components";
---

<section class="socials">
  <ul class="socials__list" role="list">
    {socials.map((item) => (
      <li class="socials__item">
        <a
          class={`socials__link socials__link--${item.key}`}
          href={item.url}
          aria-label={item.label}
          target="_blank"
          rel="noreferrer noopener"
          title={item.name}
        >
          <span class="socials__icon" aria-hidden="true">
            <Icon name={item.icon} class="socials__svg" />
          </span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .socials__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .socials__item {
    display: inline-flex;
    margin: 0 0.5rem 0.5rem 0;
  }

  .socials__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    text-decoration: none;
    line-height: 0;
  }

  .socials__icon {
    display: inline-flex;
    color: currentColor;
  }

  .socials__svg {
    width: 1.1rem;
    height: 1.1rem;
    display: block;
    fill: currentColor;
  }
</style>
