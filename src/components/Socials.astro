---
import socials from "../data/socials.json";
import { Icon } from "astro-icon/components";

interface SocialItem {
  key?: string;
  url: string;
  label?: string;
  name?: string;
  icon?: string;
}

const safeSocials: SocialItem[] = Array.isArray(socials) ? socials : [];
---

<section class="socials">
  <ul class="socials__list" role="list">
    {safeSocials.map((item) => (
      <li class="socials__item">
        <a
          class={`socials__link ${item.key ? `socials__link--${item.key}` : ''}`}
          href={item.url}
          aria-label={item.label || item.name || "Social link"}
          target="_blank"
          rel="noreferrer noopener"
          title={item.name || ""}
        >
          <span class="socials__icon" aria-hidden="true">
            {item.icon && <Icon name={item.icon} class="socials__svg" />}
          </span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .socials__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .socials__item {
    display: inline-flex;
    margin: 0 0.5rem 0.5rem 0;
  }

  .socials__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    text-decoration: none;
    line-height: 0;
  }

  .socials__icon {
    display: inline-flex;
    color: currentColor;
  }

  .socials__svg {
    width: 1.1rem;
    height: 1.1rem;
    display: block;
    fill: currentColor;
  }
</style>