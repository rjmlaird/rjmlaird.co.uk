---
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
---

<div class="table-wrap">
  <table class="data-table">
    {caption && <caption>{caption}</caption>}
    <slot />
  </table>
</div>

<style>
  .table-wrap {
    margin: 2rem 0;
    overflow-x: auto;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 6px;
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .data-table caption {
    caption-side: top;
    text-align: left;
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted, #666);
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }
  .data-table :global(th),
  .data-table :global(td) {
    padding: 0.6rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }
  .data-table :global(th) {
    background: var(--color-surface, #f7f7f5);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .data-table :global(tr:last-child td) {
    border-bottom: none;
  }
  .data-table :global(tr:hover td) {
    background: var(--color-surface, #f7f7f5);
  }
</style>
