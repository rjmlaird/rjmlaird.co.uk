---
// src/components/Figure.astro
interface Props {
  src: string | { src?: string } | null | undefined;
  alt: string;
  caption?: string;
  credit?: string;
  wide?: boolean;
}

const { src, alt, caption, credit, wide = false } = Astro.props;

const imgSrc = typeof src === 'string' ? src : src?.src;
---

{imgSrc && (
  <figure class:list={['post-figure', { wide }]}>
    <img src={imgSrc} alt={alt} loading="lazy" />
    {(caption || credit) && (
      <figcaption>
        {caption}
        {credit && <span class="credit"> — {credit}</span>}
      </figcaption>
    )}
  </figure>
)}

<style>
  .post-figure {
    margin: 2rem 0;
  }
  .post-figure.wide {
    margin-inline: calc(50% - 50vw);
    max-width: 100vw;
    text-align: center;
  }
  .post-figure img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
  }
  .post-figure.wide img {
    max-width: 1100px;
    margin-inline: auto;
    border-radius: 0;
  }
  figcaption {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted, #666);
    text-align: center;
  }
  .credit {
    opacity: 0.75;
  }
</style>
