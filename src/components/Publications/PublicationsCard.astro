---
interface Props {
  article: {
    id?: number;
    title: string;
    excerpt?: string;
    publication?: string;
    date?: string;
    topic?: string;
    image?: string;
    url?: string;
    variant?: "teal" | "violet" | "coral";
  };
}

const { article } = Astro.props;

// normalize fields
const number = article.id ? String(article.id).padStart(2, "0") : "";

const title = article.title ?? "Untitled";
const excerpt = article.excerpt ?? "";
const publication = article.publication ?? "";
const date = article.date ?? "";
const topic = article.topic ?? "";

const link = article.url || "#";
const variant = article.variant ?? "teal";
---

<article class="pr pub">
  <p class="pn">{number}</p>

  <!-- IMAGE (optional but structured like a project visual slot) -->
  {article.image && (
    <div class="pub-media">
      <img
        src={article.image}
        alt={title}
        loading="lazy"
      />
    </div>
  )}

  <div class="pm">
    <div class="pub-meta">
      {publication && <span>{publication}</span>}
      {date && <span>{date}</span>}
    </div>

    <h3>{title}</h3>

    <p>{excerpt}</p>

    {topic && (
      <div class="pt">
        <span class="tag">{topic}</span>
      </div>
    )}
  </div>

  <a
    href={link}
    class="pa"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="pa-i">↗</span>
    <span>Read</span>
  </a>
</article>