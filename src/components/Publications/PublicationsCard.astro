---
interface Props {
  item?: Record<string, any>;
  index?: number;
  bibText?: string;
}

const props = Astro.props as Props;
const item = props.item ?? {};
const bibText = props.bibText ?? "";
const number = props.index ? String(props.index).padStart(2, "0") : "";

const clean = (v: unknown) => (v === null || v === undefined ? "" : String(v).trim());

const normalizeAuthors = (authors: unknown) => {
  if (!Array.isArray(authors)) return "";
  return authors
    .map((a: any) => [a.given || "", a.family || ""].filter(Boolean).join(" "))
    .filter(Boolean)
    .join(", ");
};

const normalizeYear = (item: any) => item?.issued?.["date-parts"]?.[0]?.[0] || item?.year || "";
const normalizeTitle = (item: any) => (Array.isArray(item.title) ? item.title.join(" ") : item.title || "Untitled");
const normalizeContainer = (item: any) => item["container-title"] || item.journal || item.booktitle || item.publisher || "";

const normalizeType = (item: any) => {
  if (item.type === "article-journal") return "Journal article";
  if (item.type === "paper-conference") return "Conference paper";
  if (item.type === "report") return "Report";
  if (item.type === "webpage") return "Web page";
  if (item.type === "thesis") return "Thesis";
  return item.type || "Publication";
};

const normalizeUrl = (item: any) => item.URL || item.url || "";
const normalizeDoi = (item: any) => item.DOI || item.doi || "";
const normalizeAbstract = (item: any) => item.abstract || "";
const normalizeKeywords = (item: any) => {
  const raw = item.keyword || item.keywords || "";
  if (Array.isArray(raw)) return raw.map(String).filter(Boolean);
  if (typeof raw === "string") return raw.split(/[;,]/).map((s) => s.trim()).filter(Boolean);
  return [];
};

const excerptWords = (text: string, count = 40) => {
  const words = (text || "").trim().split(/\s+/).filter(Boolean);
  if (words.length <= count) return { text: text || "", more: false };
  return { text: words.slice(0, count).join(" ") + "...", more: true };
};

const pdfUrlFromItem = (item: any) => {
  const file = item.file;
  if (!file) return "";
  const raw = Array.isArray(file) ? String(file[0] || "") : String(file);
  const match = raw.match(/^[^:]+:([^:]+):application\/pdf$/i);
  return match ? `/${match[1]}` : "";
};

const title = normalizeTitle(item);
const authors = normalizeAuthors(item.author);
const year = normalizeYear(item);
const publication = normalizeContainer(item);
const type = normalizeType(item);
const abstract = normalizeAbstract(item);
const preview = excerptWords(abstract, 40);
const url = normalizeUrl(item);
const doi = normalizeDoi(item);
const recordUrl = url || (doi ? `https://doi.org/${doi}` : "");
const pdf = pdfUrlFromItem(item);
const keywords = normalizeKeywords(item);
const titleUrl = doi ? `https://doi.org/${doi}` : url;
const bibtexHref = `data:text/x-bibtex;charset=utf-8,${encodeURIComponent(bibText)}`;
---

<article class="pr pub">
  <p class="pn">{number}</p>

  <div class="pm">
    <div class="pub-top">
      <h3>{titleUrl ? <a href={titleUrl} target="_blank" rel="noopener noreferrer">{title}</a> : title}</h3>
      {year && <span class="date">{year}</span>}
    </div>

    {publication && <div class="client-badge">{publication}</div>}

    {authors && <p class="authors">{authors}</p>}

    {preview.text && <p class="abstract">{preview.text}</p>}

    {keywords.length > 0 && (
      <div class="pt">
        {keywords.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}

    {type && (
      <div class="detail-line">
        <span class="type-pill">{type}</span>
      </div>
    )}

    <div class="action-row">
      <a class="pa" href={bibtexHref} download="publications.bib" target="_blank" rel="noopener noreferrer">
        <span>BibTeX</span>
      </a>
      {doi && (
        <a class="pa" href={`https://doi.org/${doi}`} target="_blank" rel="noopener noreferrer">
          <span>DOI</span>
        </a>
      )}
      {pdf && (
        <a class="pa" href={pdf} target="_blank" rel="noopener noreferrer">
          <span>Download</span>
        </a>
      )}
      {recordUrl && (
        <a class="pa pa-primary" href={recordUrl} target="_blank" rel="noopener noreferrer">
          <span>View</span>
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .pub {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 0;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .pub::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.02), rgba(0, 0, 0, 0.02));
    opacity: 0;
    transition: opacity 180ms ease;
    z-index: 0;
  }

  .pub:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
    border-color: color-mix(in srgb, currentColor 24%, transparent);
  }

  .pub:hover::before {
    opacity: 1;
  }

  .pn,
  .pm,
  .pa {
    position: relative;
    z-index: 2;
  }

  .pn {
    margin-bottom: 0.9rem;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.65;
  }

  .pm {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    min-width: 0;
    width: 100%;
  }

  .pub-top,
  .authors,
  .abstract,
  .detail-line,
  .pt,
  .action-row {
    width: 100%;
    min-width: 0;
    max-width: none;
  }

  .pub-top {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pub-top h3 {
    margin: 0;
    line-height: 1.12;
    font-size: clamp(1.05rem, 1vw + 0.9rem, 1.25rem);
    letter-spacing: -0.02em;
    overflow-wrap: anywhere;
    width: 100%;
  }

  .pub-top a {
    color: inherit;
    text-decoration: none;
    display: inline-block;
    width: 100%;
  }

  .pub-top a:hover {
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .date {
    font-size: 0.86rem;
    opacity: 0.72;
    width: 100%;
  }

  .client-badge {
    display: inline-flex;
    width: fit-content;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
  }

  .authors,
  .abstract {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.9;
    overflow-wrap: anywhere;
    white-space: normal;
    width: 100%;
  }

  .authors {
    color: color-mix(in srgb, currentColor 86%, transparent);
  }

  .abstract {
    color: color-mix(in srgb, currentColor 88%, transparent);
  }

  .pt {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.15rem;
  }

  .tag,
  .pa {
    display: inline-flex;
    width: fit-content;
    padding: 0.38rem 0.72rem;
    border-radius: 999px;
    font-size: 0.75rem;
    line-height: 1;
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
  }

  .detail-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.84rem;
    opacity: 0.82;
  }

  .type-pill {
    display: inline-flex;
    width: fit-content;
    padding: 0.42rem 0.75rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid color-mix(in srgb, currentColor 16%, transparent);
    background: color-mix(in srgb, currentColor 7%, transparent);
    color: var(--teal);
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.2rem;
  }

  .pa {
    text-decoration: none;
    transition: transform 160ms ease, background-color 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .pa-primary {
    font-weight: 700;
  }

  .pa:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, currentColor 28%, transparent);
    background: color-mix(in srgb, currentColor 8%, transparent);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
  }

  @media (max-width: 640px) {
    .pub-top h3 {
      font-size: 1.02rem;
    }

    .pm {
      gap: 1rem;
    }

    .pa {
      width: 100%;
      justify-content: center;
    }
  }
</style>
