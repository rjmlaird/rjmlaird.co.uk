---
// src/components/ProjectSidebar.astro
export interface Props {
  sectors?: string[];
  tools?: string[];
  features?: string[];
  relatedExperience?: any[];
  relatedEducation?: any[];
  relatedOrganisations?: any[];
  relatedVolunteering?: any[];
  relatedAwards?: any[];
  relatedCaseStudies?: any[];
  relatedProjects?: any[];
  relatedInitiatives?: any[];
  relatedVideos?: any[];
  links?: {
    github?: string;
    web?: string;
    demo?: string;
    docs?: string;
    youtube?: string;
    store?: string;
    api?: string;
  };
}

const {
  sectors = [],
  tools = [],
  features = [],
  relatedExperience = [],
  relatedEducation = [],
  relatedOrganisations = [],
  relatedVolunteering = [],
  relatedAwards = [],
  relatedCaseStudies = [],
  relatedProjects = [],
  relatedInitiatives = [],
  relatedVideos = [],
  links = {},
} = Astro.props as Props;
---

<aside class="project-sidebar" aria-label="Project sidebar">
  {sectors.length > 0 && (
    <section class="sidebar-block">
      <h2>Sectors</h2>
      <ul class="chip-list">
        {sectors.map((sector: string) => {
          const slug = sector
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-|-$/g, '');
          return (
            <li>
              <a href={`/sectors/${slug}`} style="border: none; padding: 0; background: none;">
                {sector}
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {tools.length > 0 && (
    <section class="sidebar-block">
      <h2>Tools</h2>
      <ul class="chip-list">
        {tools.map((tool: string) => <li>{tool}</li>)}
      </ul>
    </section>
  )}

  {features.length > 0 && (
    <section class="sidebar-block">
      <h2>Features</h2>
      <ul class="bullet-list">
        {features.map((feature: string) => <li>{feature}</li>)}
      </ul>
    </section>
  )}

  {relatedExperience.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Experience</h2>
      <ul class="bullet-list">
        {relatedExperience.map((item: any) => {
          const label = item.title ?? item.name ?? item.role ?? "Experience item";
          const href = item.id
            ? `https://cv.rjmlaird.co.uk/#${item.id}`
            : "https://cv.rjmlaird.co.uk/";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedEducation.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Education</h2>
      <ul class="bullet-list">
        {relatedEducation.map((item: any) => {
          const label = item.title ?? item.name ?? item.school ?? "Education item";
          const href = item.id
            ? `https://cv.rjmlaird.co.uk/#${item.id}`
            : item.url ?? item.href ?? "#";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedVolunteering.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Volunteering</h2>
      <ul class="bullet-list">
        {relatedVolunteering.map((item: any) => {
          const label = item.title ?? item.name ?? item.role ?? "Volunteering";
          const href = item.id
            ? `https://cv.rjmlaird.co.uk/#${item.id}`
            : item.url ?? item.href ?? "#";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedOrganisations.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Organisations</h2>
      <ul class="bullet-list">
        {relatedOrganisations.map((item: any) => {
          const label = item.title ?? item.name ?? "Organisation";
          const href = item.id
            ? `https://cv.rjmlaird.co.uk/#${item.id}`
            : item.url ?? item.website ?? item.href ?? "#";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedAwards.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Awards</h2>
      <ul class="bullet-list">
        {relatedAwards.map((item: any) => {
          const label = item.title ?? item.name ?? "Award";
          const href = item.id
            ? `https://cv.rjmlaird.co.uk/#${item.id}`
            : item.url ?? item.website ?? item.href ?? "#";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedCaseStudies.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Case Studies</h2>
      <ul class="bullet-list">
        {relatedCaseStudies.map((item: any) => {
          const label = item.data?.title ?? item.title ?? item.name ?? "Case Study";
          const href = item.slug
            ? `/case-studies/${item.slug}`
            : item.data?.slug
            ? `/case-studies/${item.data.slug}`
            : item.url ?? item.href ?? "#";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedProjects.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Projects</h2>
      <ul class="bullet-list">
        {relatedProjects.map((item: any) => {
          const label = item.data?.title ?? item.title ?? item.name ?? "Project";
          const href = item.slug
            ? `/projects/${item.slug}`
            : item.data?.slug
            ? `/projects/${item.data.slug}`
            : item.url ?? item.href ?? "#";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedInitiatives.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Initiatives</h2>
      <ul class="bullet-list">
        {relatedInitiatives.map((item: any) => {
          const label = item.data?.title ?? item.title ?? item.name ?? "Initiatives";
          const href = item.slug
            ? `/initiatives/${item.slug}`
            : item.data?.slug
            ? `/initiatives/${item.data.slug}`
            : item.url ?? item.href ?? "#";

          return (
            <li>
              <a href={href}>{label}</a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {relatedVideos.length > 0 && (
    <section class="sidebar-block">
      <h2>Related Videos</h2>
      <ul class="bullet-list">
        {relatedVideos.map((item: any) => {
          const label = item.title ?? "Video";
          const href =
            item.url ??
            (item.youtubeId ? `https://www.youtube.com/watch?v=${item.youtubeId}` : "#");

          return (
            <li>
              <a href={href} target="_blank" rel="noreferrer">
                {label} <span class="sr-only">(opens in new tab)</span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {(links?.github || links?.web || links?.youtube || links?.demo || links?.docs || links?.store || links?.api) && (
    <section class="sidebar-block">
      <h2>Links</h2>
      <ul class="link-list">
        {links?.github && (
          <li>
            <a href={links.github} target="_blank" rel="noreferrer">
              GitHub <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        )}

        {links?.web && (
          <li>
            <a href={links.web} target="_blank" rel="noreferrer">
              Website <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        )}

        {links?.demo && (
          <li>
            <a href={links.demo} target="_blank" rel="noreferrer">
              Demo <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        )}

        {links?.docs && (
          <li>
            <a href={links.docs} target="_blank" rel="noreferrer">
              Docs <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        )}

        {links?.youtube && (
          <li>
            <a href={links.youtube} target="_blank" rel="noreferrer">
              YouTube <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        )}

        {links?.store && (
          <li>
            <a href={links.store} target="_blank" rel="noreferrer">
              Store <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        )}

        {links?.api && (
          <li>
            <a href={links.api} target="_blank" rel="noreferrer">
              API <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        )}
      </ul>
    </section>
  )}
</aside>
