---
export interface Props {
  items: string[];
  title?: string;
}

const { items, title = "Checklist" } = Astro.props as Props;
---

<section class="not-prose my-8 rounded-2xl border border-slate-200 bg-white p-5">
  <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500">{title}</p>
  <ul class="space-y-3">
    {items.map((item) => (
      <li class="flex gap-3">
        <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
          ✓
        </span>
        <span class="leading-7">{item}</span>
      </li>
    ))}
  </ul>
</section>
