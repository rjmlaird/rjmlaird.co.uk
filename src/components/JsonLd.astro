---
// src/components/JsonLd.astro
export interface Props {
  json: Record<string, any> | Record<string, any>[];
  id?: string;
}

const { json, id = "jsonld" } = Astro.props as Props;

function safeJsonLd(data: Record<string, any> | Record<string, any>[]) {
  return JSON.stringify(data)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026");
}
---

<script type="application/ld+json" id={id} set:html={safeJsonLd(json)} is:inline />