---
type Project = {
  slug: string;
  title?: string;
  type?: string;
  status?: string;
  description?: string;
  date?: Date | string;
  tools_tech?: string[];
  features?: string[];
  tags?: string[];
  links?: {
    github?: string;
    live?: string;
    website?: string;
    demo?: string;
    docs?: string;
    repo?: string;
    api?: string;
  };
  impact?: Record<string, unknown>;
};

const { project, slug } = Astro.props as {
  project: Project;
  slug: string;
};

const dateValue = project.date ? new Date(project.date) : null;
const links = project.links ?? {};
const liveLink = links.live || links.demo || links.github || links.docs;
const formattedDate = dateValue
  ? dateValue.toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
  : "";
---

<article class="pr pub" style="display: flex; flex-direction: column; width: 100%; max-width: none; flex: 1 1 100%;">
  <div class="pub-main" style="flex: 1; width: 100%;">
    <div class="pm" style="width: 100%; max-width: none;">
      <div class="pub-top">
        <h3>
          <a href={`/projects/${slug}/`} class="project-title-link">
            {project.title}
          </a>
        </h3>
        <time class="date" datetime={dateValue?.toISOString()}>
          {formattedDate}
        </time>
      </div>

      <div class="client-badge">{project.type}</div>
      <div class="client-badge">{project.status}</div>

      <p>{project.description}</p>

      {project.features?.length ? (
        <div class="pt">
          {project.features.slice(0, 3).map((feature) => (
            <span class="tag">{feature}</span>
          ))}
        </div>
      ) : null}

      {project.tools_tech?.length ? (
        <div class="pt">
          {project.tools_tech.slice(0, 4).map((tool) => (
            <span class="tag">{tool}</span>
          ))}
        </div>
      ) : null}
    </div>
  </div>

  <div class="pub-links">
    {liveLink ? (
      <a class="btn-link" href={`/projects/${slug}/#projects`} target="_blank" rel="noreferrer">
        View project
      </a>
    ) : null}
  </div>
</article>