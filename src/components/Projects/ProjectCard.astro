---
interface Props {
  project: {
    id: number;
    slug: string;
    title: string;
    type: string;
    status: string;
    description: string;
    date: string;
    tools_tech: string[];
    features: string[];
    tags: string[];
    links?: {
      github?: string;
      live?: string;
      demo?: string;
      docs?: string;
      video?: string;
      store?: string;
      api?: string;
    };
  };
  slug: string;
}

const { project, slug } = Astro.props;
const links = project.links ?? {};
const liveLink = links.live || links.demo || links.github || links.docs;
const number = project.id ? String(project.id).padStart(2, "0") : "";
---

<article class="pr pub">
  <p class="pn">{number}</p>

  <div class="pub-main">
    <div class="pm">
      <div class="pub-top">
        <h3>
          <a href={`/projects/${slug}/`} class="project-title-link">
            {project.title}
          </a>
        </h3>
        <span class="date">{project.date}</span>
      </div>

      <div class="client-badge">{project.type}</div>
      <div class="client-badge">{project.status}</div>

      <p>{project.description}</p>

      {project.features?.length ? (
        <div class="pt">
          {project.features.slice(0, 3).map((feature) => (
            <span class="tag">{feature}</span>
          ))}
        </div>
      ) : null}

      {project.tools_tech?.length ? (
        <div class="pt">
          {project.tools_tech.slice(0, 4).map((tool) => (
            <span class="tag">{tool}</span>
          ))}
        </div>
      ) : null}
    </div>
  </div>

  <div class="pub-links">
    {links.github ? (
      <a
        class="btn-link github-badge"
        href={links.github}
        target="_blank"
        rel="noreferrer"
        aria-label="View GitHub repository"
      >
        <span class="gh-icon" aria-hidden="true">⌂</span>
        <span>GitHub</span>
      </a>
    ) : null}

    {liveLink ? (
      <a class="btn-link" href={liveLink} target="_blank" rel="noreferrer">
        View project
      </a>
    ) : null}
  </div>
</article>
