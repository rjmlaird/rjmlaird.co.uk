---
import { slugify } from '../../utils/slugify';

type Project = {
  slug: string;
  title?: string;
  type?: string;
  status?: string;
  description?: string;
  startDate?: Date | string;
  tools_tech?: string[];
  features?: string[];
  tags?: string[];
  links?: {
    github?: string;
    live?: string;
    website?: string;
    demo?: string;
    docs?: string;
    repo?: string;
    api?: string;
  };
  impact?: Record<string, unknown>;
};

const { project, slug } = Astro.props as {
  project: Project;
  slug: string;
};

// NOTE: the content schema field is `startDate`, not `date` — using the
// wrong key here meant every card silently rendered an empty date.
const dateValue = project.startDate ? new Date(project.startDate) : null;
const formattedDate = dateValue
  ? dateValue.toLocaleDateString("en-GB", { month: "short", year: "numeric" })
  : "";

const tags = Array.isArray(project.tags) ? project.tags : [];
const badges = [project.type, project.status].filter(Boolean) as string[];
---

<article class="project-card">
  <div class="card-top">
    <h3>
      <a href={`/projects/${slug}/`}>{project.title}</a>
    </h3>
    {formattedDate && (
      <time class="date" datetime={dateValue?.toISOString()}>{formattedDate}</time>
    )}
  </div>

  {badges.length > 0 && (
    <div class="badges" aria-label="Project type and status">
      {badges.map((label) => <span class="badge">{label}</span>)}
    </div>
  )}

  {project.description && <p class="description">{project.description}</p>}

  {tags.length > 0 && (
    <ul class="tag-row" aria-label="Tags">
      {tags.slice(0, 4).map((tag) => (
        <li><a href={`/tags/${slugify(tag)}/`}>#{tag}</a></li>
      ))}
    </ul>
  )}

  <a class="view-link" href={`/projects/${slug}/`}>
    View project <span aria-hidden="true">→</span>
  </a>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.4rem 1.5rem;
    border: 1px solid var(--bd);
    border-radius: 1rem;
    background: var(--card);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--bm);
    transform: translateY(-2px);
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }
  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.3;
  }
  h3 a {
    color: var(--w);
    text-decoration: none;
  }
  h3 a:hover,
  h3 a:focus-visible {
    color: var(--teal);
  }
  .date {
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--m);
    white-space: nowrap;
  }
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .badge {
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: capitalize;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--bm);
    color: var(--m);
  }
  .description {
    margin: 0 0 0.85rem;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--mb);
    flex-grow: 1;
  }
  .tag-row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 1rem;
    padding: 0;
  }
  .tag-row a {
    font-size: 0.72rem;
    color: var(--m);
    text-decoration: none;
    border: 1px solid var(--bd);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
  }
  .tag-row a:hover,
  .tag-row a:focus-visible {
    color: var(--teal);
    border-color: var(--teal);
  }
  .view-link {
    align-self: flex-start;
    margin-top: auto;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--teal);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .view-link:hover,
  .view-link:focus-visible {
    text-decoration: underline;
  }
</style>
