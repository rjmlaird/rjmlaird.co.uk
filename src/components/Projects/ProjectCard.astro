---
import ProjectOutcome from "./ProjectOutcome.astro";

interface Props {
  project: {
    id?: string | number;
    title: string;
    description?: string;
    summary?: string;
    tools?: string[];
    features?: string[];

    github?: string;
    repository?: string;
    live?: string;
    url?: string;

    outcome?: string;
    variant?: "teal" | "violet" | "coral";

    metrics?: string[];
    tags?: string[];
  };
}

const { project } = Astro.props;

/**
 * ----------------------------
 * NORMALISED VIEW MODEL
 * ----------------------------
 */
const id =
  project.id !== undefined ? String(project.id).padStart(2, "0") : "";

const title = project.title ?? "Untitled Project";

const description =
  project.description ?? project.summary ?? "";

const tags =
  project.tools ??
  project.tags ??
  [];

const features =
  project.features ?? [];

const link =
  project.live ??
  project.url ??
  project.github ??
  project.repository ??
  "#";

const outcome = project.outcome ?? "";

const variant = project.variant ?? "teal";

const metrics = project.metrics ?? [];
---

<article class="pr">
  <p class="pn">{id}</p>

  <div class="pm">
    <h3>{title}</h3>

    <p>{description}</p>

    {/* Tags / Tools */}
    {(tags.length > 0 || features.length > 0) && (
      <div class="pt">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}

        {features.map((feature) => (
          <span class="tag">{feature}</span>
        ))}
      </div>
    )}

    {/* Optional metrics (future-proofing for impact-led storytelling) */}
    {metrics.length > 0 && (
      <div class="pt">
        {metrics.map((m) => (
          <span class="tag">{m}</span>
        ))}
      </div>
    )}
  </div>

  {/* Outcome block (impact layer) */}
  {outcome && (
    <ProjectOutcome variant={variant} text={outcome} />
  )}

  <a
    href={link}
    class="pa"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="pa-i">↗</span>
    <span>View</span>
  </a>
</article>