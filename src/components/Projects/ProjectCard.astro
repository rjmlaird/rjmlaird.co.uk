---
import type { CollectionEntry } from "astro:content";
import CategoryBadge from "../CategoryBadge.astro";
import TagList from "../TagList.astro";
import Figure from "../Figure.astro";

interface Props {
  project?: CollectionEntry<"projects">;
  initiative?: CollectionEntry<"initiatives">;
  caseStudy?: CollectionEntry<"caseStudies">;
  featured?: boolean;
}

const { project, initiative, caseStudy, featured = false } = Astro.props as Props;

const source = project ?? initiative ?? caseStudy;
const kind = project ? "project" : initiative ? "initiative" : "caseStudy";
const data = source?.data;

const title = data?.title ?? "";
const description = data?.description ?? "";
const excerpt = data?.excerpt ?? "";
const tags = data?.tags ?? [];
const type = data?.type ?? "";
const status = data?.status ?? "";
const client = data?.client ?? "";
const organisation = data?.organisation ?? "";
const institution = data?.institution ?? "";
const startDate = data?.startDate;
const heroImage = data?.heroImage ?? "";
const heroAlt = (data?.heroAlt ?? title) || "Hero image";

const safeTags = Array.isArray(tags) ? tags : [];
const primaryType = type || status || client || organisation || institution || "";
const dateValue = startDate ? new Date(startDate) : null;
const formattedDate = dateValue
  ? dateValue.toLocaleDateString("en-GB", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : "";

const slug = source?.id ?? "";
const basePath =
  kind === "initiative"
    ? "initiatives"
    : kind === "caseStudy"
      ? "case-studies"
      : "projects";

const href = `/${basePath}/${slug}/`;
---

<article class:list={["project-card", { featured }]}>
  {heroImage && (
    <a href={href} class="project-card-image-link" aria-label={title}>
      <Figure src={heroImage} alt={heroAlt} />
    </a>
  )}

  <div class="body">
    {primaryType && <CategoryBadge category={primaryType} as="span" />}

    <h2>
      <a href={href} class="title-link">{title}</a>
    </h2>

    {(description || excerpt) && <p class="description">{description || excerpt}</p>}

    {safeTags.length > 0 && (
      <div class="meta-block">
        <TagList tags={safeTags} limit={3} />
      </div>
    )}

    <div class="footer">
      {formattedDate && <time datetime={dateValue?.toISOString()}>{formattedDate}</time>}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .project-card:hover {
    border-color: var(--color-accent, #3949ab);
    transform: translateY(-2px);
  }

  .project-card-image-link {
    display: block;
  }

  .body {
    padding: 1.1rem 1.2rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  h2 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .featured h2 {
    font-size: 1.5rem;
  }

  .title-link {
    color: inherit;
    text-decoration: none;
  }

  .title-link:hover {
    color: var(--color-accent, #3949ab);
  }

  .description {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted, #666);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta-block {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.2rem;
  }

  .footer {
    font-size: 0.78rem;
    color: var(--color-text-muted, #666);
    margin-top: 0.3rem;
  }

  .featured {
    grid-column: 1 / -1;
  }

  @media (min-width: 800px) {
    .featured {
      flex-direction: row;
    }

    .featured .project-card-image-link {
      width: 65%;
    }

    .featured .body {
      flex: 1;
      justify-content: center;
    }
  }
</style>
