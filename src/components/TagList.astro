---
interface Props {
  tags: string[];
  limit?: number; // truncate long lists on cards; omit on the full post page
}

const { tags = [], limit } = Astro.props;
const safeTags = Array.isArray(tags) ? tags : [];
const visible = limit ? safeTags.slice(0, limit) : safeTags;
const overflow = limit && safeTags.length > limit ? safeTags.length - limit : 0;

const slugify = (t: string) => (t ? t.toLowerCase().replace(/\s+/g, '-') : '');
---

{visible.length > 0 && (
  <ul class="tag-list">
    {visible.map((tag) => (
      <li>
        <a href={`/blog/tags/${slugify(tag)}`} class="tag">#{tag}</a>
      </li>
    ))}
    {overflow > 0 && <li class="overflow">+{overflow}</li>}
  </ul>
)}

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tag {
    font-size: 0.75rem;
    color: var(--color-text-muted, #666);
    text-decoration: none;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 6px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .tag:hover {
    border-color: var(--color-accent, #3949ab);
    color: var(--color-accent, #3949ab);
  }
  .overflow {
    font-size: 0.75rem;
    color: var(--color-text-muted, #666);
    padding: 0.15rem 0.3rem;
  }
</style>