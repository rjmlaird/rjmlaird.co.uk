---
import OrbitGraphic from "./OrbitGraphic.astro";
import Credentials from "./Credentials.astro";

interface Props {
  title: string;
  surname: string;
  tagline: string;
  description: string;
}

const { title, surname, tagline, description } = Astro.props as Props;
---

<section id="hero">
  <div class="orb" aria-hidden="true">
    <OrbitGraphic />
  </div>

  <p class="kk">{tagline}</p>

  <h1 class="nm">
    {title}<br />
    <span class="d">{surname}</span>
  </h1>

  <p class="creds">
    <Credentials />
  </p>

  <p class="hp">{description}</p>

  <div class="hb">
    <a href="#story" class="bp">Read story</a>
    <a href="#work" class="bo">Projects</a>
    <a href="#journalism" class="bo">Writing</a>
  </div>
</section>
