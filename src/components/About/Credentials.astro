---
import credly from "../data/credly.json";

const certifications = credly?.certifications ?? [];
const learningBadges = credly?.learning_badges ?? [];
---

<section id="badges" class="badges">
  <p class="sl">Badges & certifications</p>

  {certifications.length > 0 && (
    <>
      <h3 class="section-title">Certifications</h3>
      <div class="badge-grid">
        {certifications.map((badge) => (
          <article class="badge-card">
            {badge.imageUrl && (
              <img
                src={badge.imageUrl}
                alt={badge.name}
                class="badge-image"
                loading="lazy"
              />
            )}

            <div class="badge-body">
              <h4>{badge.name}</h4>
              <p class="badge-meta">{badge.issuer}</p>
              {badge.level && <p class="badge-meta">{badge.level}</p>}
              {badge.issueDate && <p class="badge-meta">Issued {badge.issueDate}</p>}
              {badge.expiryDate && <p class="badge-meta">Expires {badge.expiryDate}</p>}
              {badge.badgeUrl && (
                <a class="badge-link" href={badge.badgeUrl} target="_blank" rel="noreferrer">
                  View badge
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </>
  )}

  {learningBadges.length > 0 && (
    <>
      <h3 class="section-title">Learning badges</h3>
      <div class="badge-grid">
        {learningBadges.map((badge) => (
          <article class="badge-card">
            {badge.imageUrl && (
              <img
                src={badge.imageUrl}
                alt={badge.name}
                class="badge-image"
                loading="lazy"
              />
            )}

            <div class="badge-body">
              <h4>{badge.name}</h4>
              <p class="badge-meta">{badge.issuer}</p>
              {badge.issueDate && <p class="badge-meta">Issued {badge.issueDate}</p>}
              {badge.badgeUrl && (
                <a class="badge-link" href={badge.badgeUrl} target="_blank" rel="noreferrer">
                  View badge
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </>
  )}
</section>

<style>
  .badges {
    display: grid;
    gap: 1.5rem;
  }

  .section-title {
    margin: 0;
    font-size: 1.1rem;
  }

  .badge-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .badge-card {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
  }

  .badge-image {
    width: 72px;
    height: 72px;
    object-fit: contain;
  }

  .badge-body {
    display: grid;
    gap: 0.35rem;
  }

  .badge-body h4 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
  }

  .badge-meta {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .badge-link {
    margin-top: 0.25rem;
    font-size: 0.9rem;
    text-decoration: underline;
  }

  @media (min-width: 720px) {
    .badge-card {
      grid-template-columns: 84px 1fr;
      align-items: start;
    }
  }
</style>
