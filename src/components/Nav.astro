---
import nav from "../data/nav.json";

type NavChild = {
  id: string;
  label: string;
};

type NavItem = {
  id: string;
  label: string;
  children?: NavChild[];
};

const items = nav as NavItem[];
---

<nav class="site-nav" data-nav aria-label="Primary">
  <div class="nav-left">
    <a href="/" class="logo">RJM<span>Laird</span></a>
  </div>

  <div class="nav-center">
    <ul class="nl">
      {items.map((item) => {
        const hasChildren = Boolean(item.children?.length);

        return (
          <li class:list={["nitem", hasChildren && "has-dropdown"]}>
            {hasChildren ? (
              <>
                <button class="nav-link nav-parent" type="button" aria-expanded="false">
                  {item.label}
                </button>

                <ul class="dropdown">
                  {item.children!.map((child) => (
                    <li>
                      <a href={`/${child.id}`}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a class="nav-link" href={`/${item.id}`}>{item.label}</a>
            )}
          </li>
        );
      })}
    </ul>
  </div>

  <div class="nav-right">
    <a href="https://cv.rjmlaird.co.uk" class="nsub">Full CV ↗</a>
    <a href="/contact" class="ncta">Get in touch</a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav-menu">
      <span class="sr-only">Toggle navigation</span>
      <span class="hamburger" aria-hidden="true"></span>
    </button>
  </div>

  <script is:inline>
    const initNav = () => {
      const siteNav = document.querySelector("[data-nav]");
      if (!siteNav) return;

      const toggle = siteNav.querySelector(".nav-toggle");
      const dropdownButtons = siteNav.querySelectorAll(".nav-parent");

      const closeAllDropdowns = () => {
        siteNav.querySelectorAll(".has-dropdown").forEach((item) => {
          item.classList.remove("open");
          const btn = item.querySelector(".nav-parent");
          if (btn) btn.setAttribute("aria-expanded", "false");
        });
      };

      dropdownButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const parent = btn.closest(".has-dropdown");
          if (!parent) return;

          const isOpen = parent.classList.toggle("open");
          btn.setAttribute("aria-expanded", String(isOpen));
        });
      });

      toggle?.addEventListener("click", () => {
        const open = siteNav.classList.toggle("menu-open");
        toggle.setAttribute("aria-expanded", String(open));
        if (!open) closeAllDropdowns();
      });

      document.addEventListener(
        "click",
        (event) => {
          if (!siteNav.contains(event.target)) closeAllDropdowns();
        },
        { once: true }
      );
    };

    initNav();
    document.addEventListener("astro:page-load", initNav);
  </script>
</nav>
<style>
.site-nav {
  position: relative;
  z-index: 300;
  width: 100%;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 1.5rem;
  padding: 1rem var(--gutter);
  background: rgba(11, 15, 26, 0.93);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--bd);
}

.nav-left {
  justify-self: start;
}

.nav-center {
  justify-self: center;
  min-width: 0;
}

.nav-right {
  justify-self: end;
  display: flex;
  align-items: center;
  gap: 0.7rem;
}

.logo {
  font-family: var(--D);
  font-size: 0.93rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--w);
  text-decoration: none;
}

.logo span {
  color: var(--teal);
}

.nl {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.6rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav-link {
  font-family: var(--D);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--m);
  text-decoration: none;
  letter-spacing: 0.04em;
  background: none;
  border: 0;
  padding: 0;
  cursor: pointer;
}

.nav-link:hover,
.nav-link:focus-visible {
  color: var(--w);
}

.nsub {
  font-family: var(--D);
  font-size: 0.7rem;
  font-weight: 500;
  color: var(--m);
  text-decoration: none;
  border: 1px solid var(--bm);
  padding: 0.28rem 0.65rem;
  border-radius: 3px;
}

.ncta {
  font-family: var(--D);
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--ink);
  background: var(--teal);
  padding: 0.36rem 0.95rem;
  border-radius: 3px;
  text-decoration: none;
}

.nav-toggle {
  display: none;
}

</style>