---
import nav from "../data/nav.json";

type NavChild = {
  id: string;
  label: string;
};

type NavItem = {
  id: string;
  label: string;
  children?: NavChild[];
};

const items = nav as NavItem[];
---

<nav class="site-nav" data-nav aria-label="Primary">
  <div class="nav-left">
    <a href="/" class="logo">RJM<span>Laird</span></a>
  </div>

  <div class="nav-right">
    <a href="https://cv.rjmlaird.co.uk" class="nsub">Full CV ↗</a>
    <a href="/contact" class="ncta">Get in touch</a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav-menu"
    >
      <span class="sr-only">Toggle navigation</span>
      <span class="hamburger" aria-hidden="true"></span>
    </button>
  </div>

  <div class="nav-center">
    <ul id="site-nav-menu" class="nl">
      {items.map((item) => {
        const hasChildren = Boolean(item.children?.length);

        return (
          <li class:list={["nitem", hasChildren && "has-dropdown"]}>
            {hasChildren ? (
              <>
                <button
                  class="nav-link nav-parent"
                  type="button"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls={`${item.id}-submenu`}
                >
                  {item.label}
                </button>

                <ul
                  id={`${item.id}-submenu`}
                  class="dropdown"
                  hidden
                >
                  {item.children!.map((child) => (
                    <li>
                      <a href={`/${child.id}`}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a class="nav-link" href={`/${item.id}`}>{item.label}</a>
            )}
          </li>
        );
      })}
    </ul>
  </div>

  <script is:inline>
    const initNav = () => {
      const siteNav = document.querySelector("[data-nav]");
      if (!siteNav) return;

      const toggle = siteNav.querySelector(".nav-toggle");
      const menu = siteNav.querySelector("#site-nav-menu");
      const dropdownButtons = siteNav.querySelectorAll<HTMLButtonElement>(".nav-parent");

      const closeAllDropdowns = () => {
        siteNav.querySelectorAll(".has-dropdown").forEach((item) => {
          item.classList.remove("open");
          const btn = item.querySelector<HTMLButtonElement>(".nav-parent");
          const submenu = item.querySelector<HTMLUListElement>(".dropdown");
          if (btn) btn.setAttribute("aria-expanded", "false");
          if (submenu) submenu.hidden = true;
        });
      };

      dropdownButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const parent = btn.closest(".has-dropdown");
          if (!parent) return;

          const submenu = parent.querySelector<HTMLUListElement>(".dropdown");
          const isOpen = parent.classList.toggle("open");
          btn.setAttribute("aria-expanded", String(isOpen));
          if (submenu) submenu.hidden = !isOpen;
        });

        btn.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            btn.click();
          }
        });
      });

      toggle?.addEventListener("click", () => {
        const open = siteNav.classList.toggle("menu-open");
        toggle.setAttribute("aria-expanded", String(open));
        if (menu) menu.setAttribute("data-open", String(open));
        if (!open) closeAllDropdowns();
      });

      document.addEventListener("click", (event) => {
        if (!siteNav.contains(event.target as Node)) {
          closeAllDropdowns();
        }
      });
    };

    initNav();
    document.addEventListener("astro:page-load", initNav);
  </script>
</nav>

<style>
.site-nav {
  position: relative;
  z-index: 300;
  width: 100%;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 1.5rem;
  padding: 1rem var(--gutter);
  background: rgba(11, 15, 26, 0.93);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--bd);
}

.nav-left {
  justify-self: start;
}

.nav-center {
  justify-self: center;
  min-width: 0;
}

.nav-right {
  justify-self: end;
  display: flex;
  align-items: center;
  gap: 0.7rem;
}

.logo {
  font-family: var(--D);
  font-size: 0.93rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--w);
  text-decoration: none;
}

.logo span {
  color: var(--teal);
}

.nl {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.6rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.nitem {
  position: relative;
}

.nav-link {
  font-family: var(--D);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--m);
  text-decoration: none;
  letter-spacing: 0.04em;
  background: none;
  border: 0;
  padding: 0.4rem 0;
  cursor: pointer;
}

.nav-link:hover,
.nav-link:focus-visible {
  color: var(--w);
}

.dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  margin-top: 0.4rem;
  min-width: 10rem;
  list-style: none;
  padding: 0.4rem 0.6rem;
  border-radius: 4px;
  background: rgba(11, 15, 26, 0.97);
  border: 1px solid var(--bd);
}

.dropdown li a {
  display: block;
  font-family: var(--D);
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--m);
  text-decoration: none;
  padding: 0.3rem 0;
}

.dropdown li a:hover,
.dropdown li a:focus-visible {
  color: var(--w);
}

.nsub {
  font-family: var(--D);
  font-size: 0.7rem;
  font-weight: 500;
  color: var(--m);
  text-decoration: none;
  border: 1px solid var(--bm);
  padding: 0.4rem 0.65rem;
  border-radius: 3px;
}

.ncta {
  font-family: var(--D);
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--ink);
  background: var(--teal);
  padding: 0.4rem 0.95rem;
  border-radius: 3px;
  text-decoration: none;
}

.nav-toggle {
  display: none;
  border: 1px solid var(--bm);
  border-radius: 3px;
  background: transparent;
  color: var(--m);
  padding: 0.4rem 0.6rem;
  cursor: pointer;
  align-items: center;
  gap: 0.3rem;
  font-family: var(--D);
  font-size: 0.75rem;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.hamburger {
  display: inline-block;
  width: 1.1rem;
  height: 0.09rem;
  background: var(--m);
  position: relative;
}
.hamburger::before,
.hamburger::after {
  content: "";
  position: absolute;
  left: 0;
  width: 1.1rem;
  height: 0.09rem;
  background: var(--m);
}
.hamburger::before {
  top: -0.28rem;
}
.hamburger::after {
  top: 0.28rem;
}

/* Mobile layout */
@media (max-width: 720px) {
  .site-nav {
    grid-template-columns: auto auto;
    grid-template-rows: auto auto;
    align-items: center;
  }

  .nav-center {
    grid-column: 1 / -1;
    justify-self: stretch;
  }

  .nav-right {
    justify-self: end;
    gap: 0.4rem;
  }

  .nl {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.8rem;
    margin-top: 0.75rem;
  }

  .site-nav.menu-open .nl {
    display: flex;
  }

  .nav-toggle {
    display: inline-flex;
  }

  .dropdown {
    position: static;
    margin-top: 0;
    margin-left: 0;
    width: 100%;
    padding-inline: 0;
    border-radius: 0;
    border-left: 0;
    border-right: 0;
  }

  .nsub {
    display: none; /* optional on small screens */
  }
}

/* Larger tap targets for touch */
.nav-link,
.ncta,
.nsub {
  padding-block: 0.4rem;
}
</style>