---
export interface Props {
  quote?: string;
  cite?: string;
}

const { quote = "", cite } = Astro.props as Props;
---

<figure class="quote-block">
  <blockquote>
    “{quote}”
  </blockquote>
  {cite && <figcaption>— {cite}</figcaption>}
</figure>

<style>
  .quote-block {
    margin-block: 2rem;
    padding: 1rem 1.4rem;
    border-left: 4px solid var(--color-accent, #3949ab);
    background: var(--color-surface, #f7f7f5);
  }
  blockquote {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-text, #1a1a1a);
  }
  figcaption {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted, #666);
  }
</style>