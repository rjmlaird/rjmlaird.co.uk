---
interface Article {
  id?: number | string;
  title?: string;
  excerpt?: string;
  publication?: string;
  startDate?: string;
  date?: string; // Added to support both naming conventions safely
  tag?: string;
  image?: string;
  url?: string;
  variant?: "teal" | "violet" | "coral";
  video?: string;
}

interface Props {
  article?: Article;
}

const { article } = Astro.props as Props;
const data = article ?? {};

const number = data.id ? String(data.id).padStart(2, "0") : "";
const title = data.title ?? "Untitled";
const excerpt = data.excerpt ?? "";
const publication = data.publication ?? "";
const startDate = data.startDate ?? data.date ?? "";
const tag = data.tag ?? "";
const link = data.url || "#";

const getYouTubeId = (url: string) => {
  try {
    const u = new URL(url);
    if (u.pathname.startsWith("/embed/")) return u.pathname.split("/embed/")[1]?.split("?")[0] ?? "";
    if (u.hostname.includes("youtu.be")) return u.pathname.replace("/", "").split("?")[0];
    const v = u.searchParams.get("v");
    if (v) return v;
    const shorts = u.pathname.match(/\/shorts\/([^/]+)/);
    return shorts?.[1] ?? "";
  } catch {
    return "";
  }
};

const videoUrl = data.video ?? data.url ?? "";
const videoId = videoUrl ? getYouTubeId(videoUrl) : "";
const embedUrl = videoId ? `https://www.youtube-nocookie.com/embed/${videoId}` : "";
const fallbackThumb = data.image || (videoId ? `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg` : "");
---

<article class="pr pub">
  <p class="pn">{number}</p>

  {embedUrl ? (
    <div class="pub-media pub-video">
      <iframe
        src={embedUrl}
        title={title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      />
    </div>
  ) : fallbackThumb ? (
    <div class="pub-media pub-image">
      <img src={fallbackThumb} alt={title} loading="lazy" />
    </div>
  ) : null}

  <div class="pm">
    <div class="pub-top">
      <h3>{title}</h3>
      {startDate && <span class="startDate">{startDate}</span>}
    </div>

    {publication && <div class="client-badge">{publication}</div>}

    {excerpt && <p>{excerpt}</p>}

    {tag && (
      <div class="pt">
        <a href={`/tags/${tag}`} class="tag">
          {tag}
        </a>
      </div>
    )}
  </div>

  <a href={link} class="pa" target="_blank" rel="noopener noreferrer">
    <span class="pa-i">↗</span>
    <span>View</span>
  </a>
</article>

<style>
  .pub {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .pub::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.02), rgba(0, 0, 0, 0.02));
    opacity: 0;
    transition: opacity 180ms ease;
    z-index: 0;
  }

  .pub:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
    border-color: color-mix(in srgb, currentColor 24%, transparent);
  }

  .pub:hover::before {
    opacity: 1;
  }

  .pn,
  .pm,
  .pa {
    position: relative;
    z-index: 2;
  }

  .pub-media {
    position: relative;
    z-index: 3;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1rem;
    background: #111;
    margin-bottom: 1rem;
  }

  .pub-video iframe,
  .pub-image img {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .pub-image img {
    object-fit: cover;
  }

  .pub-top {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 0.7rem;
  }

  .pub-top h3 {
    margin: 0;
    line-height: 1.15;
  }

  .startDate {
    font-size: 0.9rem;
    opacity: 0.72;
  }

  .client-badge {
    display: inline-flex;
    width: fit-content;
    padding: 0.35rem 0.65rem;
    margin-bottom: 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    line-height: 1;
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
  }
</style>