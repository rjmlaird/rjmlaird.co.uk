---
export interface Props {
  items: { label: string; value: string }[];
  ariaLabel?: string;
}

const { items, ariaLabel } = Astro.props as Props;
const visible = (items ?? []).filter((i) => i.value);
---

{visible.length > 0 && (
  <dl class="meta-list" aria-label={ariaLabel}>
    {visible.map((item) => (
      <div class="meta-item">
        <dt>{item.label}</dt>
        <dd>{item.value}</dd>
      </div>
    ))}
  </dl>
)}

<style>
  .meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    margin: 0.75rem 0 0;
  }
  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  dt {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted, #8a8a8a);
  }
  dd {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: capitalize;
  }
</style>
