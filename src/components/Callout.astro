---
type CalloutType = 'note' | 'tip' | 'warning';

interface Props {
  type?: CalloutType;
}

const { type = 'note' } = Astro.props;

const config: Record<CalloutType, { icon: string; label: string }> = {
  note: { icon: 'ℹ', label: 'Note' },
  tip: { icon: '✦', label: 'Tip' },
  warning: { icon: '▲', label: 'Warning' },
};

const { icon, label } = config[type];
---

<div class:list={['callout', type]} role="note">
  <span class="icon" aria-hidden="true">{icon}</span>
  <div class="body">
    <p class="label">{label}</p>
    <div class="content">
      <slot />
    </div>
  </div>
</div>

<style>
  .callout {
    display: flex;
    gap: 0.75rem;
    margin-block: 1.75rem;
    padding: 1rem 1.2rem;
    border-radius: 6px;
    border: 1px solid transparent;
  }
  .callout .icon {
    font-size: 1rem;
    line-height: 1.5;
    flex-shrink: 0;
  }
  .label {
    margin: 0 0 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .content {
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .content :global(p:last-child) {
    margin-bottom: 0;
  }

  .note {
    background: #eef3fb;
    border-color: #cfe0f5;
  }
  .note .label,
  .note .icon {
    color: #2563a8;
  }

  .tip {
    background: #eef8f1;
    border-color: #cbe8d4;
  }
  .tip .label,
  .tip .icon {
    color: #1f8a4c;
  }

  .warning {
    background: #fdf3ea;
    border-color: #f2ddc2;
  }
  .warning .label,
  .warning .icon {
    color: #b3661a;
  }
</style>
