---
// src/pages/case-studies/index.astro
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../../components/Projects/ProjectCard.astro";
import Filters from "../../components/Projects/Filters.astro";

const caseStudies = await getCollection("caseStudies", ({ data }) => data.draft !== true);

const sortedCaseStudies = caseStudies.sort((a, b) =>
  (a.data.title ?? "").localeCompare(b.data.title ?? "")
);
---

<Layout
  title="Case Studies"
  description="Space, sustainability and science-communication case studies — filter by date, client, tags, type and status."
>
  <section class="project-index">
    <div class="container pg-shell">
      <header class="pg-head">
        <p class="eyebrow">Case Studies</p>

        <h1 class="ch fade">
          Case Studies across <em>space, sustainability &amp; science policy</em>
        </h1>
      </header>

      <Filters projects={sortedCaseStudies} />

      <div class="grid" id="projectGrid">
        {sortedCaseStudies.map((caseStudy) => (
          <ProjectCard caseStudy={caseStudy} />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .project-index {
    padding: 2rem 1rem 3rem;
  }

  .pg-head {
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted, #666);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ch {
    margin: 0;
    line-height: 1.15;
  }

  .ch em {
    font-style: normal;
    color: var(--color-accent, #3949ab);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
