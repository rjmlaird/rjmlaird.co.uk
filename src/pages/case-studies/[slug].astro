---
// src/pages/case-studies/[slug].astro
import Layout from "../../layouts/Layout.astro";
import {
  getCollection,
  render,
  type CollectionEntry,
  getEntry,
} from "astro:content";
import MetaList from "../../components/MetaList.astro";
import ImpactStats from "../../components/ImpactStats.astro";
import { slugify } from "../../utils/slugify";

export async function getStaticPaths() {
  const entries = await getCollection("caseStudy", ({ data }) => data.draft !== true);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as {
  entry: CollectionEntry<"caseStudy">;
};

const slug = Astro.params.slug;
const caseStudy = entry ? entry.data : ({} as any);
const { Content } = entry ? await render(entry) : { Content: null };

const dateLabel = caseStudy.startDate
  ? new Date(caseStudy.startDate).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
    })
  : "";

const tools = Array.isArray(caseStudy.tools_tech) ? caseStudy.tools_tech : [];
const features = Array.isArray(caseStudy.features) ? caseStudy.features : [];
const tags = Array.isArray(caseStudy.tags) ? caseStudy.tags : [];
const links = caseStudy.links || {};

const relatedProjects = Array.isArray(caseStudy.relatedProjects)
  ? (await Promise.all(caseStudy.relatedProjects.map((ref: any) => getEntry(ref)))).filter(Boolean)
  : [];

const metaItems = [
  { label: "Type", value: caseStudy.type ?? "" },
  { label: "Status", value: caseStudy.status ?? "" },
  { label: "Date", value: dateLabel },
];

const pageTitle = caseStudy.title || slug || "Case study";
const pageDescription = caseStudy.description || caseStudy.excerpt || `Case study details for ${pageTitle}.`;

const baseUrl = Astro.site?.href;
const pageUrl = baseUrl ? new URL(`/case-studies/${slug}/`, baseUrl).href : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CaseStudy",
  name: pageTitle,
  description: pageDescription,
  url: pageUrl,
  keywords: tags.length > 0 ? tags.join(", ") : undefined,
  creator: { "@type": "Person", name: "Ryan Laird" },
};
---

<Layout title={pageTitle} description={pageDescription} image={caseStudy.image}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </Fragment>
  <section class="section publications-gallery">
    <div class="container pg-shell">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/case-studies/">Case studies</a></li>
          <li aria-current="page">{pageTitle}</li>
        </ol>
      </nav>

      <header class="pg-head">
        <p class="eyebrow">Case Studies</p>
        <h1 class="ch fade">{pageTitle}</h1>

        <MetaList items={metaItems} ariaLabel="Case study metadata" />
      </header>

      <div class="project-layout">
        <aside class="project-sidebar" aria-label="Case study details">
          <div class="pg-intro">
            {caseStudy.description && <p class="pg-lead">{caseStudy.description}</p>}
            <p class="pg-note">
              A full case study with metadata, links, related projects, and supporting detail.
            </p>
          </div>

          {caseStudy.client && (
            <section class="sidebar-block">
              <h2>Client</h2>
              <p>{caseStudy.client}</p>
            </section>
          )}

          {caseStudy.organisation && (
            <section class="sidebar-block">
              <h2>Organisation</h2>
              <p>{caseStudy.organisation}</p>
            </section>
          )}

          {caseStudy.institution && (
            <section class="sidebar-block">
              <h2>Institution</h2>
              <p>{caseStudy.institution}</p>
            </section>
          )}

          {tools.length > 0 && (
            <section class="sidebar-block">
              <h2>Tools</h2>
              <ul class="chip-list">
                {tools.map((tool: string) => <li>{tool}</li>)}
              </ul>
            </section>
          )}

          {features.length > 0 && (
            <section class="sidebar-block">
              <h2>Features</h2>
              <ul class="bullet-list">
                {features.map((feature: string) => <li>{feature}</li>)}
              </ul>
            </section>
          )}

          {tags.length > 0 && (
            <section class="sidebar-block">
              <h2>Tags</h2>
              <ul class="chip-list">
                {tags.map((tag: string) => (
                  <li><a href={`/tags/${slugify(tag)}/`}>{tag}</a></li>
                ))}
              </ul>
            </section>
          )}

          {(links.github || links.live || links.demo || links.docs || links.video) && (
            <section class="sidebar-block">
              <h2>Links</h2>
              <ul class="link-list">
                {links.github && (
                  <li>
                    <a href={links.github} target="_blank" rel="noreferrer">
                      GitHub <span class="sr-only">(opens in new tab)</span>
                    </a>
                  </li>
                )}
                {links.live && (
                  <li>
                    <a href={links.live} target="_blank" rel="noreferrer">
                      Live site <span class="sr-only">(opens in new tab)</span>
                    </a>
                  </li>
                )}
                {links.demo && (
                  <li>
                    <a href={links.demo} target="_blank" rel="noreferrer">
                      Demo <span class="sr-only">(opens in new tab)</span>
                    </a>
                  </li>
                )}
                {links.docs && (
                  <li>
                    <a href={links.docs} target="_blank" rel="noreferrer">
                      Docs <span class="sr-only">(opens in new tab)</span>
                    </a>
                  </li>
                )}
                {links.video && (
                  <li>
                    <a href={links.video} target="_blank" rel="noreferrer">
                      Video <span class="sr-only">(opens in new tab)</span>
                    </a>
                  </li>
                )}
              </ul>
            </section>
          )}

          {relatedProjects.length > 0 && (
            <section class="sidebar-block">
              <h2>Related projects</h2>
              <ul class="link-list">
                {relatedProjects.map((project: any) =>
                  project ? (
                    <li>
                      <a href={`/projects/${project.id}/`}>
                        {project.data.title}
                      </a>
                    </li>
                  ) : null
                )}
              </ul>
            </section>
          )}
        </aside>

        <article class="project-content">
          <div class="project-body">
            {Content && <Content />}
          </div>

          {caseStudy.impact && Object.keys(caseStudy.impact).length > 0 && (
            <section class="sidebar-block">
              <h2>Impact</h2>
              <ImpactStats impact={caseStudy.impact} />
            </section>
          )}
        </article>
      </div>
    </div>
  </section>
</Layout>
