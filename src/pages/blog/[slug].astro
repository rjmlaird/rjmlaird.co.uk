---
// src/pages/blog/[slug].astro

import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

import FactBox from '../../components/FactBox.astro';
import Callout from '../../components/Callout.astro';
import QuoteBlock from '../../components/QuoteBlock.astro';
import Figure from '../../components/Figure.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import Checklist from '../../components/Checklist.astro';
import StatCard from '../../components/StatCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => post.id) 
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props as {
  post: CollectionEntry<'blog'>;
};
if (!post) return Astro.redirect('/404');

const { Content, headings } = await render(post);
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const pTags = p.data.tags || [];
    const postTags = post.data.tags || [];
    
    const sharedTags = pTags.filter((t) => postTags.includes(t)).length;
    const pCat = p.data.category || [];
    const postCat = post.data.category || [];
    const sameCategory = pCat.some((c) => postCat.includes(c)) ? 1 : 0;

    return { post: p, score: sharedTags * 2 + sameCategory };
  })
  .filter((p) => p.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((p) => p.post);

const components = { 
  Image,
  img: Image,
  FactBox, 
  Callout, 
  QuoteBlock, 
  Figure, 
  ComparisonTable, 
  Checklist, 
  StatCard 
};
---

<Layout {...{ post, headings, relatedPosts }}>
  {post.data.heroImage && (
    <div class="hero-image">
      <Image src={post.data.heroImage} alt={post.data.heroAlt ?? post.data.title ?? ""} />
    </div>
  )}
  <Content components={components} />
</Layout>
