---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props as {
  post: CollectionEntry<"blog">;
};

const { Content } = await render(post);

const title = post.data.title ?? "Untitled";
const excerpt = post.data.excerpt ?? "";
const date = post.data.date ? new Date(post.data.date) : null;
const slug = post.id;
---

<Layout>
  <article class="blog-post">
    <header class="post-head container">
      <p class="eyebrow">Blog</p>
      <h1>{title}</h1>
      {excerpt ? <p class="lede">{excerpt}</p> : null}
      {date && !Number.isNaN(date.getTime()) ? (
        <time datetime={date.toISOString()}>{date.toLocaleDateString("en-GB")}</time>
      ) : null}
    </header>

    <div class="container post-body">
      <Content />
    </div>
  </article>
</Layout>
