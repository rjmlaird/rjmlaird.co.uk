---
import Layout from "../../layouts/Layout.astro";
import BlogCard from "../../components/Publications/BlogCard.astro";
import { getCollection } from "astro:content";

const normalizeTag = (value: string) =>
  value.trim().toLowerCase().replace(/\s+/g, "-");

const prettyTag = (value: string) => value.replace(/-/g, " ");

const entries = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const topicList = [...new Set(entries.flatMap((entry) => entry.data.tags))]
  .filter(Boolean)
  .sort((a, b) => a.localeCompare(b));
---

<Layout>
  <section class="section blog-gallery">
    <div class="container pg-shell">
      <header class="pg-head">
        <p class="eyebrow">Articles</p>

        <h1 class="ch fade">
          Writing across <em>space, sustainability &amp; science policy</em>
        </h1>

        <div class="pg-intro">
          <p class="pg-lead">
            Selected articles, reports, and commentary across space systems, climate intelligence, and innovation ecosystems.
          </p>

          <p class="pg-note">
            Use the filters to narrow by publication and topic. Each card links to the original piece.
          </p>
        </div>

        <div class="pg-filters" aria-label="Blog filters">
          <label class="filter-field" for="topicSelect">
            <span>Topic</span>
            <select id="topicSelect">
              <option value="all">All topics</option>
              {topicList.map((topic) => {
                const value = normalizeTag(topic);
                return <option value={value}>{prettyTag(value)}</option>;
              })}
            </select>
          </label>
        </div>
      </header>

      <div class="pg-grid" id="blogGrid">
        {entries.map((entry) => {
          const topics = entry.data.tags.map((topic) => normalizeTag(topic));

          return (
            <div class="publication-item" data-topics={topics.join(",")}>
              <BlogCard post={entry} />
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <script is:inline>
    const norm = (s) => (s || "").toLowerCase().trim();
    const topicSelect = document.getElementById("topicSelect");
    const items = document.querySelectorAll("#blogGrid .publication-item");

    const applyFilters = () => {
      const activeTopic = norm(
        /** @type {HTMLSelectElement | null} */ (topicSelect)?.value || "all"
      );

      items.forEach((el) => {
        const item = /** @type {HTMLElement} */ (el);
        const topics = (item.dataset.topics || "")
          .split(",")
          .map((t) => norm(t))
          .filter(Boolean);

        item.hidden = !(activeTopic === "all" || topics.includes(activeTopic));
      });
    };

    topicSelect?.addEventListener("change", applyFilters);
    applyFilters();
  </script>
</Layout>
