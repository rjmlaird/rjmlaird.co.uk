---
import Layout from "../layouts/Layout.astro";
import Nav from "../sections/nav.section.astro";
import PublicationsCard from "../components/Publications/PublicationsCard.astro";
import articlesData from "../data/articles.json";

const articles = Array.isArray(articlesData?.articles)
  ? articlesData.articles
  : [];

const topics = [...new Set(articles.map(a => a.topic).filter(Boolean))];
---

<Layout>
  <Nav />

  <main>
    <section id="publications">
      <p class="sl">Publications</p>

      <h1 class="ch fade">
        Writing across <em>space, sustainability & science policy</em>
      </h1>

      <p class="pub-lede fade">
        Selected articles, reports, and commentary across space systems, climate intelligence, and innovation ecosystems.
      </p>

      <!-- FILTERS -->
      <div class="filters fade" id="filters">
        <button class="filter-btn active" data-filter="all">All</button>

        {topics.map(topic => (
          <button class="filter-btn" data-filter={topic}>
            {topic}
          </button>
        ))}
      </div>

      <!-- GRID (NOW COMPONENT-DRIVEN) -->
      <div class="pub-grid fade" id="grid">
        {articles.map((article, index) => (
          <div data-topic={article.topic}>
            <PublicationsCard
              article={{
                ...article,
                id: article.id ?? index + 1
              }}
            />
          </div>
        ))}
      </div>
    </section>
  </main>

  <!-- FILTER SCRIPT (UNCHANGED LOGIC, MORE ROBUST TARGETING) -->
  <script is:inline>
    const buttons = document.querySelectorAll(".filter-btn");
    const wrappers = document.querySelectorAll("[data-topic]");

    buttons.forEach(btn => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter;

        buttons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");

        wrappers.forEach(wrapper => {
          const topic = wrapper.dataset.topic;

          wrapper.classList.toggle(
            "is-hidden",
            !(filter === "all" || topic === filter)
          );
        });
      });
    });
  </script>
</Layout>