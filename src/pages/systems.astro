---
import Layout from "../layouts/Layout.astro";
import Nav from "../sections/nav.section.astro";
import { getCollectionSafe } from "../lib/api";
import localSystems from "../data/systems.json";

// Try the live API first (once a 'systems' collection exists there); fall
// back to the curated local file otherwise.
const apiSystems = await getCollectionSafe<any[]>("systems" as any, []);
const systems = apiSystems.length ? apiSystems : localSystems.systems;
---

<Layout title="Systems — Ryan Laird">
  <Nav />

  <main class="page-main">
    <section id="systems-index">
      <p class="sl">Systems</p>

      <h1 class="ch fade">
        Software that <em>runs my work</em>
      </h1>

      <p class="page-lede fade">
        The larger, ongoing software systems behind my research, observing, and content
        workflows — planning engines, data pipelines, and the backend that serves this
        site's CV and research data.
      </p>

      <div class="idx-grid fade">
        {systems.map((system: any) => {
          const link = system.links?.live ?? system.links?.docs ?? system.links?.repo ?? system.links?.api;
          return (
            <article class="idx-card">
              <p class="idx-tag">{(system.stack ?? []).slice(0, 2).join(" · ")}</p>
              <h3>{system.title}</h3>
              <p class="idx-tagline">{system.tagline}</p>
              <p class="idx-desc">{system.description}</p>
              <div class="idx-ft">
                <span class="idx-status">{system.status}</span>
                {link && (
                  <a href={link} class="idx-link" target="_blank" rel="noopener noreferrer">
                    View ↗
                  </a>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </main>
</Layout>
