---
// src/pages/sectors/[sector].astro
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../utils/slugify';

export async function getStaticPaths() {
  const [posts, projects, caseStudies, initiatives] = await Promise.all([
    getCollection('blog', (p) => !p.data.draft),
    getCollection('projects', (p) => p.data.draft !== true),
    getCollection('caseStudies', (p) => p.data.draft !== true),
    getCollection('initiatives', (p) => p.data.draft !== true),
  ]);

  const sectorMap = new Map<string, string>(); // slug -> display label

  for (const entry of [...posts, ...projects, ...caseStudies, ...initiatives]) {
    const data = entry.data as { sectors?: unknown };
    if (Array.isArray(data.sectors)) {
      for (const sector of data.sectors) {
        if (typeof sector === 'string') {
          sectorMap.set(slugify(sector), sector);
        }
      }
    }
  }

  return Array.from(sectorMap.entries()).map(([slug, label]) => ({
    params: { sector: slug },
    props: { label },
  }));
}

const { sector } = Astro.params;
const { label } = Astro.props;

const matchesSector = (entrySectors: unknown) =>
  Array.isArray(entrySectors) &&
  entrySectors.some((s) => slugify(s) === sector);

const posts = (
  await getCollection('blog', (p) =>
    !p.data.draft && matchesSector((p.data as { sectors?: unknown }).sectors)
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const projects = await getCollection(
  'projects',
  (p) =>
    p.data.draft !== true &&
    matchesSector((p.data as { sectors?: unknown }).sectors)
);

const caseStudies = await getCollection(
  'caseStudies',
  (p) =>
    p.data.draft !== true &&
    matchesSector((p.data as { sectors?: unknown }).sectors)
);

const initiatives = await getCollection(
  'initiatives',
  (p) =>
    p.data.draft !== true &&
    matchesSector((p.data as { sectors?: unknown }).sectors)
);

const totalCount =
  posts.length + projects.length + caseStudies.length + initiatives.length;
---

<Layout
  title={`#${label} — Sector content`}
  description={`Blog posts, projects, initiatives and case studies in the ${label} sector.`}
>
  <section class="archive">
    <p class="eyebrow">Sector</p>
    <h1>#{label}</h1>
    <p class="count">
      {totalCount} {totalCount === 1 ? 'item' : 'items'} in the "{label}" sector
    </p>

    {posts.length > 0 && (
      <>
        <h2 class="group-title">Blog posts</h2>
        <div class="grid">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      </>
    )}

    {projects.length > 0 && (
      <>
        <h2 class="group-title">Projects</h2>
        <ul class="simple-list">
          {projects.map((entry) => {
            const data = entry.data as { title?: string; description?: string };
            return (
              <li>
                <a href={`/projects/${entry.id}/`}>
                  <span class="item-title">{data.title}</span>
                  {data.description && (
                    <span class="item-desc">{data.description}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </>
    )}

    {caseStudies.length > 0 && (
      <>
        <h2 class="group-title">Case studies</h2>
        <ul class="simple-list">
          {caseStudies.map((entry) => {
            const data = entry.data as { title?: string; description?: string };
            return (
              <li>
                <a href={`/case-studies/${entry.id}/`}>
                  <span class="item-title">{data.title}</span>
                  {data.description && (
                    <span class="item-desc">{data.description}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </>
    )}

    {initiatives.length > 0 && (
      <>
        <h2 class="group-title">Initiatives</h2>
        <ul class="simple-list">
          {initiatives.map((entry) => {
            const data = entry.data as { title?: string; description?: string };
            return (
              <li>
                <a href={`/initiatives/${entry.id}/`}>
                  <span class="item-title">{data.title}</span>
                  {data.description && (
                    <span class="item-desc">{data.description}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </>
    )}

    {totalCount === 0 && <p class="empty">Nothing in the "{label}" sector yet.</p>}
  </section>
</Layout>

<style>
  .archive {
    max-width: 1100px;
    margin-inline: auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent, #3949ab);
    margin: 0 0 0.3rem;
  }
  h1 {
    margin: 0 0 0.4rem;
  }
  .count {
    margin: 0 0 2rem;
    color: var(--color-text-muted, #666);
    font-size: 0.9rem;
  }
  .group-title {
    font-size: 1.1rem;
    margin: 2rem 0 1rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.75rem;
  }
  .simple-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .simple-list a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .simple-list a:hover,
  .simple-list a:focus-visible {
    border-color: var(--color-accent, #3949ab);
  }
  .item-title {
    font-weight: 600;
  }
  .item-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted, #666);
  }
  .empty {
    color: var(--color-text-muted, #666);
  }
</style>
