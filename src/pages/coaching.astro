---
import Layout from "../layouts/Layout.astro";
import BlogCard from "../components/Publications/BlogCard.astro";
import { getCollection } from "astro:content";

const toTime = (value) => {
  const time = value ? new Date(value).getTime() : 0;
  return Number.isFinite(time) ? time : 0;
};

const entries = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => toTime(b.data.date) - toTime(a.data.date));

const topicList = [
  ...new Set(
    entries.flatMap((entry) => {
      if (Array.isArray(entry.data.tags) && entry.data.tags.length > 0) return entry.data.tags;
      if (entry.data.tag) return [entry.data.tag];
      return [];
    })
  ),
].sort();
---

<Layout>


  <section class="section blog-gallery">
    <div class="container pg-shell">
      <header class="pg-head">
        <p class="eyebrow">Coaching</p>

      <h1 class="ch fade">
        Writing across <em>space, sustainability & science policy</em>
      </h1>
        <div class="pg-intro">
          <p class="pg-lead">
            Selected articles, reports, and commentary across space systems, climate intelligence, and innovation ecosystems.
          </p>

          <p class="pg-note">
            Use the filters to narrow by publication and topic. Each card links to the original piece.
          </p>
        </div>

        <div class="pg-filters" aria-label="Blog filters">

          <label class="filter-field" for="topicSelect">
            <span>Topic</span>
            <select id="topicSelect">
              <option value="all">All topics</option>
              {topicList.map((topic) => (
                <option value={topic}>{topic}</option>
              ))}
            </select>
          </label>
        </div>
      </header>

      <div class="pg-grid" id="blogGrid">
        {entries.map((entry) => {
          const topics = Array.isArray(entry.data.tags) && entry.data.tags.length > 0
            ? entry.data.tags
            : entry.data.tag
              ? [entry.data.tag]
              : [];

          return (
            <div class="publication-item" data-topics={topics.join(",")}>
              <BlogCard post={entry} />
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <script>
    const norm = (s) => (s || "").toLowerCase().trim();
    const topicSelect = document.getElementById("topicSelect");
    const items = document.querySelectorAll("#blogGrid .publication-item");

    const applyFilters = () => {
      const activeTopic = norm(topicSelect?.value || "all");

      items.forEach((el) => {
        const topics = (el.dataset.topics || "")
          .split(",")
          .map((t) => norm(t))
          .filter(Boolean);

        el.hidden = !(activeTopic === "all" || topics.includes(activeTopic));
      });
    };

    topicSelect?.addEventListener("change", applyFilters);
    applyFilters();
  </script>
</Layout>

<style>
  .publications-gallery {
    padding-block: clamp(4rem, 7vw, 7rem);
  }

  .pg-shell {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .pg-head {
    max-width: 78rem;
    display: grid;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    opacity: 0.72;
  }

  .pg-head h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
  }

  .pg-intro {
    max-width: 72ch;
    padding: 1rem 1.25rem;
    border-left: 3px solid color-mix(in srgb, currentColor 28%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
    border-radius: 0.9rem;
    display: grid;
    gap: 0.85rem;
  }

  .pg-lead,
  .pg-note {
    margin: 0;
    line-height: 1.65;
  }

  .pg-lead {
    font-size: 1.08rem;
    font-weight: 500;
    opacity: 0.96;
  }

  .pg-note {
    font-size: 0.98rem;
    opacity: 0.84;
  }

  .pg-filters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .filter-field {
    display: grid;
    gap: 0.45rem;
  }

  .filter-field span {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.7;
  }

  .filter-field select {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border-radius: 0.9rem;
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    background: transparent;
    color: currentColor;
    font: inherit;
  }

  .filter-field select option {
    color: #111;
    background: #fff;
  }

  .pg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  .publication-item[hidden] {
    display: none;
  }

  :global(.pub-media) {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1rem;
    background: #111;
    margin-bottom: 1rem;
  }

  :global(.pub-media img),
  :global(.pub-media iframe) {
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
  }

  :global(.pub-media img) {
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 640px) {
    :global(.pub-media) {
      aspect-ratio: 4 / 3;
      margin-bottom: 0.85rem;
    }
  }
</style>
