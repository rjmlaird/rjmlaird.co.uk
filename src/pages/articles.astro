---
import articlesData from "../data/articles.json";
import Layout from "../layouts/Layout.astro";
import PublicationsCard from "../components/Publications/ArticlesCard.astro";

const toTime = (value) => {
  const time = new Date(value || 0).getTime();
  return Number.isFinite(time) ? time : 0;
};

const articles = Array.isArray(articlesData?.articles) ? articlesData.articles : [];
const sortedArticles = [...articles].sort((a, b) => toTime(b.date) - toTime(a.date));

const publications = [...new Set(sortedArticles.map((a) => a.publication).filter(Boolean))].sort();

const topicList = [
  ...new Set(
    sortedArticles.flatMap((article) => {
      if (Array.isArray(article.topics) && article.topics.length > 0) return article.topics;
      if (article.topic) return [article.topic];
      return [];
    })
  ),
].sort();
---

<Layout>

  <section class="section publications-gallery">
    <div class="container pg-shell">
      <header class="pg-head">
        <p class="eyebrow">Articles</p>

      <h1 class="ch fade">
        Writing across <em>space, sustainability & science policy</em>
      </h1>
        <div class="pg-intro">
          <p class="pg-lead">
            Selected articles, reports, and commentary across space systems, climate intelligence, and innovation ecosystems.
          </p>

          <p class="pg-note">
            Use the filters to narrow by publication and topic. Each card links to the original piece.
          </p>
        </div>

        <div class="pg-filters" aria-label="Publication filters">
          <label class="filter-field" for="publicationSelect">
            <span>Publication</span>
            <select id="publicationSelect">
              <option value="all">All publications</option>
              {publications.map((publication) => (
                <option value={publication}>{publication}</option>
              ))}
            </select>
          </label>

          <label class="filter-field" for="topicSelect">
            <span>Topic</span>
            <select id="topicSelect">
              <option value="all">All topics</option>
              {topicList.map((topic) => (
                <option value={topic}>{topic}</option>
              ))}
            </select>
          </label>
        </div>
      </header>

      <div class="pg-grid" id="publicationGrid">
        {sortedArticles.map((article, index) => (
          <div
            class="publication-item"
            data-publication={article.publication || ""}
            data-topics={(Array.isArray(article.topics) && article.topics.length > 0
              ? article.topics
              : article.topic
                ? [article.topic]
                : []
            ).join(",")}
          >
            <PublicationsCard
              article={{
                ...article,
                id: article.id ?? index + 1,
                topic: Array.isArray(article.topics) ? article.topics[0] ?? article.topic : article.topic,
              }}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const norm = (s) => (s || "").toLowerCase().trim();

  const publicationSelect = document.getElementById("publicationSelect");
  const topicSelect = document.getElementById("topicSelect");
  const items = document.querySelectorAll("#publicationGrid .publication-item");

  const applyFilters = () => {
    const activePublication = norm(publicationSelect?.value || "all");
    const activeTopic = norm(topicSelect?.value || "all");

    items.forEach((el) => {
      const publication = norm(el.dataset.publication);
      const topics = norm(el.dataset.topics);
      const topicList = topics ? topics.split(",").map((t) => t.trim()).filter(Boolean) : [];

      const publicationOk = activePublication === "all" || publication === activePublication;
      const topicOk = activeTopic === "all" || topicList.includes(activeTopic);

      el.hidden = !(publicationOk && topicOk);
    });
  };

  publicationSelect?.addEventListener("change", applyFilters);
  topicSelect?.addEventListener("change", applyFilters);
  applyFilters();
</script>

<style>
  .publications-gallery {
    padding-block: clamp(4rem, 7vw, 7rem);
  }

  .pg-shell {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .pg-head {
    max-width: 78rem;
    display: grid;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    opacity: 0.72;
  }

  .pg-head h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
  }

  .pg-intro {
    max-width: 72ch;
    padding: 1rem 1.25rem;
    border-left: 3px solid color-mix(in srgb, currentColor 28%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
    border-radius: 0.9rem;
    display: grid;
    gap: 0.85rem;
  }

  .pg-lead,
  .pg-note {
    margin: 0;
    line-height: 1.65;
  }

  .pg-lead {
    font-size: 1.08rem;
    font-weight: 500;
    opacity: 0.96;
  }

  .pg-note {
    font-size: 0.98rem;
    opacity: 0.84;
  }

  .pg-filters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .filter-field {
    display: grid;
    gap: 0.45rem;
  }

  .filter-field span {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.7;
  }

  .filter-field select {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border-radius: 0.9rem;
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    background: transparent;
    color: currentColor;
    font: inherit;
  }

  .filter-field select option {
    color: #111;
    background: #fff;
  }

  .pg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  .publication-item[hidden] {
    display: none;
  }

  :global(.pub-media) {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1rem;
    background: #111;
    margin-bottom: 1rem;
  }

  :global(.pub-media img),
  :global(.pub-media iframe) {
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
  }

  :global(.pub-media img) {
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 640px) {
    :global(.pub-media) {
      aspect-ratio: 4 / 3;
      margin-bottom: 0.85rem;
    }
  }
</style>
