---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("projects", ({ data }) => {
    return data.draft !== true;
  });

  return entries.map((entry) => {
    const slug = entry.data.slug || entry.id;

    if (!slug) {
      throw new Error(`Missing slug for project entry: ${entry.id}`);
    }

    return {
      params: { slug: String(slug) },
      props: { entry, slug: String(slug) },
    };
  });
}

const { entry, slug } = Astro.props as {
  entry: CollectionEntry<"projects">;
  slug: string;
};

const project = entry.data;
const { Content } = await render(entry);

const dateLabel = project.date
  ? new Date(`${project.date}-01`).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
    })
  : "";

const tools = Array.isArray(project.tools_tech) ? project.tools_tech : [];
const features = Array.isArray(project.features) ? project.features : [];
const tags = Array.isArray(project.tags) ? project.tags : [];
const links = project.links || {};
---

<Layout>
  <section class="section publications-gallery">
    <div class="container pg-shell">
      <header class="pg-head">
        <p class="eyebrow">Projects</p>
        <h1 class="ch fade">{project.title || slug}</h1>

        <dl class="project-meta" aria-label="Project metadata">
          {project.type && (
            <div>
              <dd>{project.type}</dd>
            </div>
          )}
          {project.status && (
            <div>
              <dd>{project.status}</dd>
            </div>
          )}
          {dateLabel && (
            <div>
              <dd>{dateLabel}</dd>
            </div>
          )}
        </dl>
      </header>

      <div class="project-layout">
        <aside class="project-sidebar" aria-label="Project details">
          <div class="pg-intro">
            {project.description && <p class="pg-lead">{project.description}</p>}
            <p class="pg-note">
              A full project case study with metadata, links, and supporting detail.
            </p>
          </div>

          {tools.length > 0 && (
            <section class="sidebar-block">
              <h2>Tools</h2>
              <ul class="chip-list">
                {tools.map((tool: string) => <li>{tool}</li>)}
              </ul>
            </section>
          )}

          {features.length > 0 && (
            <section class="sidebar-block">
              <h2>Features</h2>
              <ul class="bullet-list">
                {features.map((feature: string) => <li>{feature}</li>)}
              </ul>
            </section>
          )}

          {tags.length > 0 && (
            <section class="sidebar-block">
              <h2>Tags</h2>
              <ul class="chip-list">
                {tags.map((tag: string) => <li>{tag}</li>)}
              </ul>
            </section>
          )}

          {(links.github || links.live) && (
            <section class="sidebar-block">
              <h2>Links</h2>
              <ul class="link-list">
                {links.github && (
                  <li>
                    <a href={links.github} target="_blank" rel="noreferrer">
                      GitHub
                    </a>
                  </li>
                )}
                {links.live && (
                  <li>
                    <a href={links.live} target="_blank" rel="noreferrer">
                      Live site
                    </a>
                  </li>
                )}
              </ul>
            </section>
          )}
        </aside>

        <article class="project-content">
          <div class="project-body">
            <Content />
          </div>

          <section class="sidebar-block">
            <h2>Impact</h2>
            {project.impact && Object.keys(project.impact).length > 0 ? (
              <pre>{JSON.stringify(project.impact, null, 2)}</pre>
            ) : (
              <p>No impact data provided yet.</p>
            )}
          </section>
        </article>
      </div>
    </div>
  </section>
</Layout>


<style>
  .publications-gallery {
    padding-block: clamp(4rem, 7vw, 7rem);
  }

  .pg-shell {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .pg-head {
    max-width: 78rem;
    display: grid;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    opacity: 0.72;
  }

  .pg-head h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
  }

  .pg-intro {
    max-width: 72ch;
    padding: 1rem 1.25rem;
    border-left: 3px solid color-mix(in srgb, currentColor 28%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
    border-radius: 0.9rem;
    display: grid;
    gap: 0.85rem;
  }

  .pg-lead,
  .pg-note {
    margin: 0;
    line-height: 1.65;
  }

  .pg-lead {
    font-size: 1.08rem;
    font-weight: 500;
    opacity: 0.96;
  }

  .pg-note {
    font-size: 0.98rem;
    opacity: 0.84;
  }

  .pg-filters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .filter-field {
    display: grid;
    gap: 0.45rem;
  }

  .filter-field span {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.7;
  }

  .filter-field select {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border-radius: 0.9rem;
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    background: transparent;
    color: currentColor;
    font: inherit;
  }

  .filter-field select option {
    color: #111;
    background: #fff;
  }

  .pg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  .publication-item[hidden] {
    display: none;
  }

  :global(.pub-media) {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1rem;
    background: #111;
    margin-bottom: 1rem;
  }

  :global(.pub-media img),
  :global(.pub-media iframe) {
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
  }

  :global(.pub-media img) {
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 640px) {
    :global(.pub-media) {
      aspect-ratio: 4 / 3;
      margin-bottom: 0.85rem;
    }
  }
</style>

