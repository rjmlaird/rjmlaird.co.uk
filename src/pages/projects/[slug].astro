---
// src/pages/projects/[slug].astro
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import ProjectSidebar from "../../components/ProjectSidebar.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import ImpactStats from "../../components/ImpactStats.astro";
import { getExperience, getEducation, getVolunteering, getAwards } from "@/lib/api";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";

import videosData from "../../data/videos.json";

export async function getStaticPaths() {
  const entries = await getCollection("projects", ({ data }) => data.draft !== true);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as {
  entry: CollectionEntry<"projects">;
};

const slug = Astro.params.slug;
const project = entry.data;
const { Content } = await render(entry);

const sectors = Array.isArray(project.sectors) ? project.sectors : [];
const tools = Array.isArray(project.tools_tech) ? project.tools_tech : [];
const features = Array.isArray(project.features) ? project.features : [];
const links = project.links || {};

const youtubeUrl = (project as any).youtubeUrl || links.youtube;
const youtubeId = project.youtubeId;

const [experienceItems, educationItems, volunteeringItems, awardsItems, caseStudyItems, initiativeItems] =
  await Promise.all([
    getExperience(),
    getEducation(),
    getVolunteering(),
    getAwards(),
    getCollection("caseStudies"),
    getCollection("initiatives"),
  ]);

const relatedExperienceIds = Array.isArray(project.relatedExperience) ? project.relatedExperience : [];
const relatedEducationIds = Array.isArray(project.relatedEducation) ? project.relatedEducation : [];
const relatedOrgIds = Array.isArray(project.relatedOrg) ? project.relatedOrg : [];
const relatedVolunteeringIds = Array.isArray(project.relatedVolunteering) ? project.relatedVolunteering : [];
const relatedAwardIds = Array.isArray(project.relatedAwards) ? project.relatedAwards : [];
const relatedCaseStudyIds = Array.isArray(project.relatedCaseStudies) ? project.relatedCaseStudies : [];
const relatedInitiativeIds = Array.isArray(project.relatedInitiatives) ? project.relatedInitiatives : [];
const relatedVideoIds = Array.isArray(project.relatedVideos) ? project.relatedVideos : [];

const relatedExperience = experienceItems.filter((item: any) =>
  relatedExperienceIds.includes(item.id ?? item.slug)
);

const relatedEducation = educationItems.filter((item: any) =>
  relatedEducationIds.includes(item.id ?? item.slug)
);

const relatedOrganisations = volunteeringItems.filter((item: any) =>
  relatedOrgIds.includes(item.id ?? item.slug)
);

const relatedVolunteering = volunteeringItems.filter((item: any) =>
  relatedVolunteeringIds.includes(item.id ?? item.slug)
);

const relatedAwards = awardsItems.filter((item: any) =>
  relatedAwardIds.includes(item.id ?? item.slug)
);

const relatedCaseStudies = caseStudyItems.filter((item: any) =>
  relatedCaseStudyIds.includes(item.slug ?? item.id)
);

const relatedInitiatives = initiativeItems.filter((item: any) =>
  relatedInitiativeIds.includes(item.slug ?? item.id)
);

const relatedVideos = (videosData as any[]).filter((item: any) =>
  relatedVideoIds.includes(item.youtubeId ?? item.id)
);

const pageTitle = project.title || slug || "Project";
const pageDescription = project.description || project.excerpt || `Project details for ${pageTitle}.`;
---

<ProjectLayout
  project={entry}
  title={pageTitle}
  description={pageDescription}
>
  <section class="section publications-gallery">
    <div class="project-layout">
      <ProjectSidebar
        sectors={sectors}
        tools={tools}
        features={features}
        relatedExperience={relatedExperience}
        relatedEducation={relatedEducation}
        relatedOrganisations={relatedOrganisations}
        relatedVolunteering={relatedVolunteering}
        relatedAwards={relatedAwards}
        relatedCaseStudies={relatedCaseStudies}
        relatedInitiatives={relatedInitiatives}
        relatedVideos={relatedVideos}
        links={links}
      />

      <article class="project-content">
        <div class="project-body">
          <div class="pg-intro">
            {project.description && <p class="pg-lead">{project.description}</p>}
          </div>

          <YouTubeEmbed id={youtubeId} url={youtubeUrl} />

          <Content />
        </div>

        {project.impact && Object.keys(project.impact).length > 0 && (
          <section class="sidebar-block">
            <h2>Impact</h2>
            <ImpactStats impact={project.impact} />
          </section>
        )}
      </article>
    </div>
  </section>
</ProjectLayout>
