---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../sections/nav.section.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects
    .filter((project) => typeof project.slug === "string" && project.slug.length > 0)
    .map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
}

const { project } = Astro.props;

if (!project) {
  throw new Error("Project not found");
}

const { Content } = await render(project);

const title = project.data.title ?? "Untitled";
const description = project.data.description ?? "";
const date = project.data.date
  ? new Date(project.data.date)
  : null;
---

<Layout>
  <Nav />

  <article class="project-page">
    <header class="project-head container">
      <p class="eyebrow">Projects</p>
      <h1>{title}</h1>
      {description ? <p class="lede">{description}</p> : null}
      {date && !Number.isNaN(date.getTime()) ? (
        <time datetime={date.toISOString()}>{date.toLocaleDateString()}</time>
      ) : null}
    </header>

    <div class="container project-body">
      <Content />
    </div>
  </article>
</Layout>
