---
// src/pages/tags/index.astro
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { slugify } from "../../utils/slugify";

// Only use collections that have `tags` and `draft`
const [posts, projects, caseStudies, initiatives] = await Promise.all([
  getCollection("blog", ({ data }) => !data.draft),
  getCollection("projects", ({ data }) => !data.draft),
  getCollection("caseStudies", ({ data }) => !data.draft),
  getCollection("initiatives", ({ data }) => !data.draft),
]);

const allEntries = [...posts, ...projects, ...caseStudies, ...initiatives];

const tagMap = new Map<string, { label: string; count: number }>();

for (const entry of allEntries) {
  // Narrow type by checking tags field
  const data = entry.data as { tags?: unknown };
  if (!Array.isArray(data.tags)) continue;

  for (const tag of data.tags) {
    if (typeof tag !== "string") continue;
    const slug = slugify(tag);
    const existing = tagMap.get(slug);
    if (existing) {
      existing.count += 1;
    } else {
      tagMap.set(slug, { label: tag, count: 1 });
    }
  }
}

const allTags = Array.from(tagMap.entries())
  .map(([slug, { label, count }]) => ({ slug, label, count }))
  .sort((a, b) => a.label.localeCompare(b.label));
---

<Layout title="Tags" description="Browse every tag across blog posts, projects, initiatives and case studies.">
  <section class="tags-index">
    <p class="eyebrow">Browse by tag</p>
    <h1>Tags</h1>
    <p class="intro">All {allTags.length} tags used across blog posts, projects, initiatives and case studies.</p>

    <ul class="tag-list" aria-label="All tags">
      {allTags.map(({ slug, label, count }) => (
        <li>
          <a href={`/tags/${slug}/`}>
            <span class="tag-label">#{label}</span>
            <span class="tag-count">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .tags-index {
    max-width: 1100px;
    margin-inline: auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent, #3949ab);
    margin: 0 0 0.3rem;
  }
  h1 {
    margin: 0 0 0.5rem;
  }
  .intro {
    margin: 0 0 2rem;
    color: var(--color-text-muted, #666);
  }
  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .tag-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 999px;
    text-decoration: none;
    color: var(--color-text, #1a1a1a);
    font-size: 0.85rem;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .tag-list a:hover,
  .tag-list a:focus-visible {
    border-color: var(--color-accent, #3949ab);
    color: var(--color-accent, #3949ab);
  }
  .tag-count {
    color: var(--color-text-muted, #999);
    font-size: 0.75rem;
  }
</style>
