---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import ProjectSidebar from "../../components/ProjectSidebar.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import ImpactStats from "../../components/ImpactStats.astro";
import { getExperience, getEducation, getVolunteering, getAwards } from "@/lib/api";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";

export async function getStaticPaths() {
  const entries = await getCollection("initiatives", ({ data }) => data.draft !== true);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as {
  entry: CollectionEntry<"initiatives">;
};

const slug = Astro.params.slug;
const initiative = entry.data;
const { Content } = await render(entry);

const sectors = Array.isArray(initiative.sectors) ? initiative.sectors : [];
const tools = Array.isArray(initiative.tools_tech) ? initiative.tools_tech : [];
const features = Array.isArray(initiative.features) ? initiative.features : [];
const links = initiative.links || {};

const youtubeUrl = (initiative as any).youtubeUrl || links.youtube;
const youtubeId = initiative.youtubeId;

const [experienceItems, educationItems, volunteeringItems, awardsItems, projectItems] =
  await Promise.all([
    getExperience(),
    getEducation(),
    getVolunteering(),
    getAwards(),
    getCollection("projects"),
  ]);

const relatedExperienceIds = Array.isArray(initiative.relatedExperience) ? initiative.relatedExperience : [];
const relatedEducationIds = Array.isArray(initiative.relatedEducation) ? initiative.relatedEducation : [];
const relatedOrgIds = Array.isArray(initiative.relatedOrg) ? initiative.relatedOrg : [];
const relatedVolunteeringIds = Array.isArray(initiative.relatedVolunteering) ? initiative.relatedVolunteering : [];
const relatedAwardIds = Array.isArray(initiative.relatedAwards) ? initiative.relatedAwards : [];
const relatedProjectIds = Array.isArray(initiative.relatedProjects) ? initiative.relatedProjects : [];

const relatedExperience = experienceItems.filter((item: any) =>
  relatedExperienceIds.includes(item.id ?? item.slug)
);

const relatedEducation = educationItems.filter((item: any) =>
  relatedEducationIds.includes(item.id ?? item.slug)
);

const relatedOrganisations = volunteeringItems.filter((item: any) =>
  relatedOrgIds.includes(item.id ?? item.slug)
);

const relatedVolunteering = volunteeringItems.filter((item: any) =>
  relatedVolunteeringIds.includes(item.id ?? item.slug)
);

const relatedAwards = awardsItems.filter((item: any) =>
  relatedAwardIds.includes(item.id ?? item.slug)
);

const relatedProjects = projectItems.filter((item: any) =>
  relatedProjectIds.includes(item.id ?? item.slug)
);

const pageTitle = initiative.title || slug || "Initiative";
const pageDescription = initiative.description || initiative.excerpt || `Project details for ${pageTitle}.`;
---

<ProjectLayout
  initiative={entry}
  title={pageTitle}
  description={pageDescription}
>
  <section class="section publications-gallery">
    <div class="project-layout">
      <ProjectSidebar
        sectors={sectors}
        tools={tools}
        features={features}
        relatedExperience={relatedExperience}
        relatedEducation={relatedEducation}
        relatedOrganisations={relatedOrganisations}
        relatedVolunteering={relatedVolunteering}
        relatedAwards={relatedAwards}
        relatedProjects={relatedProjects}
        links={links}
      />

      <article class="project-content">
        <div class="project-body">
          <div class="pg-intro">
            {initiative.description && <p class="pg-lead">{initiative.description}</p>}
          </div>

          <YouTubeEmbed id={youtubeId} url={youtubeUrl} />

          <Content />
        </div>

        {initiative.impact && Object.keys(initiative.impact).length > 0 && (
          <section class="sidebar-block">
            <h2>Impact</h2>
            <ImpactStats impact={initiative.impact} />
          </section>
        )}
      </article>
    </div>
  </section>
</ProjectLayout>
