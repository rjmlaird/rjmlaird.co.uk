---
import Layout from "../layouts/Layout.astro";

const profile = {
  name: "Your Name",
  title: "Professional Title / Personal Brand",
  tagline: "Clear, credible, and media-ready positioning.",
  location: "London, UK",
  email: "hello@yourdomain.com",
  website: "https://yourdomain.com",
};

const facts = [
  { label: "Focus", value: "Brand strategy, content, and design" },
  { label: "Audience", value: "Founders, teams, and media" },
  { label: "Format", value: "Speaking, writing, consulting" },
  { label: "Availability", value: "Select projects" },
];

const downloads = [
  { title: "Headshots", note: "Approved press images", href: "#" },
  { title: "Logo pack", note: "SVG, PNG, light and dark", href: "#" },
  { title: "Brand sheet", note: "Fonts, colors, and usage", href: "#" },
];

const expertise = [
  "Brand strategy",
  "Content systems",
  "Editorial design",
  "Personal branding",
  "Media-ready messaging",
];

const timeline = [
  { year: "2024", event: "Launched the brand." },
  { year: "2025", event: "Expanded services and content reach." },
  { year: "2026", event: "Created a stronger press and partnership presence." },
];

const testimonials = [
  {
    quote: "Clear, strategic, and easy to work with.",
    author: "Client Name, Role",
  },
  {
    quote: "The kind of brand that makes collaboration simple.",
    author: "Partner Name, Organization",
  },
];
---
<Layout>

      <header class="pg-head">
        <p class="eyebrow">About</p>

      <h1 class="ch fade">
        Writing across <em>space, sustainability & science policy</em>
      </h1>
        <div class="pg-intro">
          <p class="pg-lead">
            Selected articles, reports, and commentary across space systems, climate intelligence, and innovation ecosystems.
          </p>

          <p class="pg-note">
            Use the filters to narrow by publication and topic. Each card links to the original piece.
          </p>
        </div>

        <div class="pg-filters" aria-label="Blog filters">

          <label class="filter-field" for="topicSelect">
            <span>Topic</span>
            <select id="topicSelect">
              <option value="all">All topics</option>
              {topicList.map((topic) => (
                <option value={topic}>{topic}</option>
              ))}
            </select>
          </label>
        </div>
      </header>

    <section class="grid">
      <article class="panel col-8">
        <h2>Bio</h2>
        <p class="meta">A concise summary for press, podcasts, speaking, and collaborations.</p>
        <p>
          Write a short paragraph here that explains who you are, what you do, and why people should care.
        </p>
      </article>

      <article class="panel col-4">
        <h2>Contact</h2>
        <ul>
          <li>Email: {profile.email}</li>
          <li>Website: {profile.website}</li>
          <li>Location: {profile.location}</li>
        </ul>
      </article>

      <article class="panel col-12">
        <h2>Key facts</h2>
        <div class="chips">
          {facts.map((fact) => (
            <span class="chip">{fact.label}: {fact.value}</span>
          ))}
        </div>
      </article>

      <article class="panel col-12">
        <h2>Downloads</h2>
        <p class="meta">Make it easy for media and partners to use the right materials.</p>
        <div class="asset-grid">
          {downloads.map((item) => (
            <div class="asset">
              <strong>{item.title}</strong>
              <p class="meta">{item.note}</p>
              <a class="btn" href={item.href}>Download</a>
            </div>
          ))}
        </div>
      </article>

      <article class="panel col-6">
        <h2>Expertise</h2>
        <div class="chips">
          {expertise.map((item) => (
            <span class="chip">{item}</span>
          ))}
        </div>
      </article>

      <article class="panel col-6">
        <h2>Timeline</h2>
        <ul>
          {timeline.map((item) => (
            <li><strong>{item.year}</strong> — {item.event}</li>
          ))}
        </ul>
      </article>

      <article class="panel col-12">
        <h2>Testimonials</h2>
        {testimonials.map((item) => (
          <blockquote class="quote">
            <p>{item.quote}</p>
            <footer class="meta">— {item.author}</footer>
          </blockquote>
        ))}
      </article>

      <article class="panel col-12">
        <h2>Brand guidelines</h2>
        <ul>
          <li>Use the approved logo files only.</li>
          <li>Keep the logo clear and unaltered.</li>
          <li>Use a consistent font system across the site.</li>
          <li>Keep tone confident, warm, and direct.</li>
          <li>Prefer short, scannable copy over long paragraphs.</li>
        </ul>
      </article>
    </section>

    <p class="footer">
      This page can be split into separate Press Kit and Brand Guidelines pages if you want a more modular experience.
    </p>

</Layout>

<style>
  .press-kit {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 40px 64px;
  }

  .hero,
  .panel {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .hero {
    padding: 40px;
    margin-bottom: 24px;
  }

  .eyebrow {
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 12px;
    color: var(--muted);
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
  }

  .lead {
    max-width: 72ch;
    margin: 16px 0 0;
    color: var(--muted);
    font-size: 1.05rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 20px;
  }

  .panel {
    padding: 24px;
  }

  .col-12 { grid-column: span 12; }
  .col-8 { grid-column: span 8; }
  .col-6 { grid-column: span 6; }
  .col-4 { grid-column: span 4; }

  h2 {
    margin: 0 0 12px;
    font-size: 1.15rem;
  }

  .meta {
    color: var(--muted);
    margin: 0 0 12px;
  }

  ul {
    margin: 12px 0 0;
    padding-left: 18px;
  }

  li {
    margin: 8px 0;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
  }

  .chip {
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 14px;
  }

  .asset-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 14px;
  }

  .asset {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 18px;
    background: #fff;
  }

  .btn {
    display: inline-block;
    margin-top: 12px;
    padding: 12px 16px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-size: 14px;
  }

  .quote {
    border-left: 3px solid var(--accent);
    padding-left: 14px;
    margin: 0 0 16px;
  }

  .footer {
    padding-top: 16px;
    color: var(--muted);
    font-size: 14px;
  }

  @media (max-width: 860px) {
    .col-8,
    .col-6,
    .col-4 {
      grid-column: span 12;
    }

    .asset-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 28px;
    }
  }
</style>
