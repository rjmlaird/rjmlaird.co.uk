---
import Layout from "../layouts/Layout.astro";
import Nav from "../sections/nav.section.astro";
import { getCollectionSafe } from "../lib/api";
import localTools from "../data/tools.json";

const apiTools = await getCollectionSafe<any[]>("tools" as any, []);
const tools = apiTools.length ? apiTools : localTools.tools;
---

<Layout title="Tools — Ryan Laird">
  <Nav />

  <main class="page-main">
    <section id="tools-index">
      <p class="sl">Tools</p>

      <h1 class="ch fade">
        Small builds, <em>real problems</em>
      </h1>

      <p class="page-lede fade">
        Scripts, one-off pipelines, and interactive prototypes — smaller in scope than the
        systems I maintain, but each one solving a specific, concrete problem.
      </p>

      <div class="idx-grid fade">
        {tools.map((tool: any) => {
          const link = tool.links?.live ?? tool.links?.docs ?? tool.links?.repo;
          return (
            <article class="idx-card">
              <p class="idx-tag">{(tool.stack ?? []).slice(0, 2).join(" · ")}</p>
              <h3>{tool.title}</h3>
              <p class="idx-tagline">{tool.tagline}</p>
              <p class="idx-desc">{tool.description}</p>
              <div class="idx-ft">
                <span class="idx-status">{tool.status}</span>
                {link && (
                  <a href={link} class="idx-link" target="_blank" rel="noopener noreferrer">
                    View ↗
                  </a>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </main>
</Layout>
