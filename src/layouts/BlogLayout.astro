---
// src/layouts/BlogLayout.astro
import Layout from './Layout.astro';
import { getEntry, type CollectionEntry } from 'astro:content';
import PostMeta from '../components/PostMeta.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import AuthorCard from '../components/AuthorCard.astro';
import { getReadingTime } from '../utils/readingTime';

interface Props {
  post?: CollectionEntry<'blog'>;
  title?: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  relatedPosts?: CollectionEntry<'blog'>[];
  body?: string;
}

const { post, headings = [], relatedPosts = [], body = '' } = Astro.props;
const { 
  title: postTitle = '', 
  description: postDescription = '', 
  pubDate = new Date(), 
  updatedDate, 
  category = '', 
  tags = [], 
  heroImage, 
  heroAlt,
  imageCredit, 
  author: authorRef 
} = post ? post.data : ({} as any);

const title = Astro.props.title || postTitle;
const description = Astro.props.description || postDescription;

let authorEntry = null;
if (authorRef && typeof authorRef === 'string') {
  try {
    authorEntry = await getEntry('authors', authorRef);
  } catch {
    authorEntry = null;
  }
}

const author = {
  name: authorEntry?.data.name ?? 'Unknown Author',
  role: authorEntry?.data.role ?? '',
  avatar: authorEntry?.data.avatar as any,
};

const readingTime = getReadingTime(body || post?.body || '');
const safeHeadings = Array.isArray(headings) ? headings : [];
const safeRelatedPosts = Array.isArray(relatedPosts) ? relatedPosts : [];
const safeCategory = Array.isArray(category) ? category[0] || '' : category;
const safeTags = Array.isArray(tags) ? tags : [];

const resolvedHeroSrc = heroImage; // string path
const resolvedHeroAlt = heroAlt || title || "Hero image";
const resolvedHeroCredit = imageCredit;
---

<Layout title={title} description={description} image={typeof resolvedHeroSrc === 'string' ? resolvedHeroSrc : undefined}>
  <main id="content">
    <article class="post">
      <header class="post-header">
        <div class="title-wrap">
          <h1>{title}</h1>
        </div>
        {description && (
          <div class="description-wrap">
            <p class="dek">{description}</p>
          </div>
        )}
      </header>

      {resolvedHeroSrc && (
        <figure class="hero">
          <img src={resolvedHeroSrc} alt={resolvedHeroAlt} width="1400" height="700" />
          {resolvedHeroCredit && <figcaption>{resolvedHeroCredit}</figcaption>}
        </figure>
      )}

      <PostMeta 
        author={author} 
        pubDate={pubDate} 
        updatedDate={updatedDate} 
        readingTime={readingTime} 
        category={safeCategory} 
        tags={safeTags} 
      />

      <div class="post-grid">
        <aside class="sidebar">
          <TableOfContents headings={safeHeadings} />
        </aside>

        <div class="prose">
          <slot />
        </div>
      </div>

      <footer class="post-footer">
        {authorEntry && <AuthorCard name={author.name} role={author.role} avatar={author.avatar} bio={authorEntry.data.bio ?? ''} compact={false} />}
        <RelatedPosts posts={safeRelatedPosts} />
      </footer>
    </article>
  </main>
</Layout>



<style>
  .post {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  .post-header {
    max-width: 70ch;
    margin: 2.5rem auto 0;
  }
  .post-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.15;
    margin: 0 0 0.75rem;
    display: block;
  }
  .post-header .dek {
    font-size: 1.15rem;
    color: var(--color-text-muted, #666);
    line-height: 1.5;
    margin: 0.5rem 0 0;
    display: block;
    clear: both;
  }
  .hero {
    margin: 2rem 0;
  }
  .hero img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .hero figcaption {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    text-align: center;
    color: var(--color-text-muted, #666);
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }
  .prose {
    max-width: 70ch;
    margin-inline: auto;
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .prose :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
  }
  .prose :global(h3) {
    font-size: 1.2rem;
    margin-top: 2rem;
  }
  .prose :global(p) {
    margin-bottom: 1.3rem;
  }
  .prose :global(img) {
    border-radius: 6px;
  }

  .post-footer {
    max-width: 70ch;
    margin: 3rem auto 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, #e5e5e5);
  }

  @media (min-width: 900px) {
    .post-grid {
      grid-template-columns: 200px 1fr;
    }
    .sidebar {
      order: 1;
    }
    .prose {
      order: 2;
      margin-inline: 0;
    }
  }
</style>
