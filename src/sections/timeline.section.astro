---
import { getExperience } from "@/lib/api";
import TimelineItem from "../components/Story/TimelineItem.astro";

type TimelineEntry = Awaited<ReturnType<typeof getExperience>>[number];

const timeline: TimelineEntry[] = await getExperience().catch(() => []);
---

<section id="timeline">
  <p class="sl">Career timeline</p>
  <h2 class="story-lede">
    From telescope data to strategic communications.
  </h2>

  <div class="thread">
    {timeline.length > 0 ? (
      timeline.map((item) => <TimelineItem item={item} />)
    ) : (
      <p>No experience data available.</p>
    )}
  </div>
</section>
