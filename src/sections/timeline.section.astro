---
// Timeline.astro
import TimelineItem from "./TimelineItem.astro";

type TimelineItemData = {
  era: string;
  title: string;
  description: string;
  colour?: "teal" | "violet" | "amber";
};

interface Props {
  items: TimelineItemData[];
}

const { items } = Astro.props;
---

<div>
  {items.map((item) => (
    <TimelineItem {...item} />
  ))}
</div>
