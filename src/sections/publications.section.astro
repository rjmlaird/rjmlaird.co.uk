---
import data from "../data/articles.json";

const articles = Array.isArray(data?.articles) ? data.articles : [];
---

<section id="journalism">
  <p class="sl">Journalism & publications</p>

  <p class="pub-lede">
    Writing across space, environment, and science policy.
  </p>

  {articles.map((article) => {
    const date = article?.date ? new Date(article.date) : null;
    const year = date ? date.getFullYear() : "";

    return (
      <a
        class="pub-row"
        href={article?.url ?? "#"}
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="pub-meta">
          <span>{article?.publication ?? "Unknown publication"}</span>
          <span>{year}</span>
        </div>

        <div class="pub-body">
          <h4>{article?.title ?? "Untitled article"}</h4>
          <p>{article?.excerpt ?? ""}</p>
        </div>

        <span class="pp">
          {article?.topic ?? "Space / Science"}
        </span>
      </a>
    );
  })}
</section>