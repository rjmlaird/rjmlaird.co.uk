---
import { getCollection } from "astro:content";
import ProjectCard from "../components/Projects/ProjectCard.astro";

const projects = (await getCollection(
  "projects",
  ({ data }) => data.draft !== true && data.featured === true
))
  .filter((entry) => typeof entry.data.id === "number");
---

<section id="projects">
  <div class="container pg-shell">
    <p class="sl">Featured Projects</p>

    {projects.map((entry) => (
      <ProjectCard project={entry.data} slug={entry.id} />
    ))}
  </div>
</section>
