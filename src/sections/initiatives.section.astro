---
import initiatives from "../data/initiatives.json";
---

<section id="initiatives">
  <p class="sl">Initiatives</p>

  <div class="init-grid">
    {initiatives.map((init) => (
      <div class="ic">
        <div class="ic-h">
          <div class="ic-mk" style={`color:${init.color ?? "var(--teal)"}`}>
            {init.icon}
          </div>

          <p class="ic-sec">{init.meta}</p>
          <h3>{init.title}</h3>
          <p>{init.description}</p>
        </div>

        {init.points?.length > 0 && (
          <div class="ic-pl">
            {init.points.map((p) => (
              <div class="ic-pi">
                <span class="ic-d"></span>
                <span>{p}</span>
              </div>
            ))}
          </div>
        )}

        <div class="ic-ft">
          <span class="ic-st">{init.status}</span>

          {init.link && init.cta && (
            <a href={init.link} class="ic-lk">
              {init.cta}
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</section>