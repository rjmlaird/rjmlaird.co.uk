---
import { getCollection } from "../lib/api";

type ProfileLink = {
  label: string;
  href: string;
};

type ProfileContact = {
  label: string;
  href: string;
};

type Profile = {
  name?: string;
  headline?: string;
  biography?: string;
  summary?: string[];
  portfolioLinks?: ProfileLink[];
  contact?: ProfileContact[];
};

const profile = (await getCollection<Profile>("profile")) ?? {};

const headline = profile.headline?.trim() ?? "";
const biography = profile.biography?.trim() ?? "";
const credentials = Array.isArray(profile.summary) ? profile.summary : [];
const links = Array.isArray(profile.portfolioLinks) ? profile.portfolioLinks : [];
const contact = Array.isArray(profile.contact) ? profile.contact : [];
---

<section id="about" aria-labelledby="about-title">
  <p class="sl">About</p>

  <div class="about-grid">
    <div>
      <h2 id="about-title" class="ah fade">
        {profile.name ?? ""}
        <br />
        <em>{headline}</em>
      </h2>

      <div class="ab fade">
        <p>{biography}</p>
      </div>

      <div class="cred-row fade" aria-label="Key credentials">
        {credentials.map((item) => (
          <span class="cred-badge cb-m">{item}</span>
        ))}
      </div>
    </div>

    <aside class="sp fade" aria-label="Find me elsewhere">
      <div class="sp-h">Find me elsewhere</div>

      {links.map((link) => (
        <a class="si" href={link.href} target="_blank" rel="noopener noreferrer">
          <div class="sl2">
            <span class="su">{link.label}</span>
          </div>
          <span class="sa" aria-hidden="true">→</span>
        </a>
      ))}

      {contact.map((item) => (
        <a class="si" href={item.href} target="_blank" rel="noopener noreferrer">
          <div class="sl2">
            <span class="su">{item.label}</span>
          </div>
          <span class="sa" aria-hidden="true">→</span>
        </a>
      ))}
    </aside>
  </div>
</section>
