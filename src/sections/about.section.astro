---
import profileData from "../data/profile.json";
import { type Profile } from "../lib/schemas/profile.schema";

type ProfileLink = {
  label: string;
  href: string;
};

type ProfileContact = {
  label: string;
  href: string;
};

type LocalProfile = Profile & {
  portfolioLinks?: ProfileLink[];
  contact?: ProfileContact[];
};

const profile = profileData as LocalProfile;

const headline = profile.headline?.trim() ?? "";
const biography = Array.isArray(profile.biography) ? profile.biography : [];
const credentials = profile.credentials?.trim() ? [profile.credentials.trim()] : [];
const tags = Array.isArray(profile.tags) ? profile.tags : [];
const links = Array.isArray(profile.portfolioLinks) ? profile.portfolioLinks : [];
const contact = Array.isArray(profile.contact) ? profile.contact : [];
---

<section id="about" aria-labelledby="about-title">
  <p class="sl">About</p>

  <div class="about-grid">
    <div>
      <h2 id="about-title" class="ah fade">
        {profile.name ?? ""}
        <br />
        <em>{headline}</em>
      </h2>

      {biography.length > 0 && (
        <div class="ab fade">
          {biography.map((paragraph: string) => <p>{paragraph}</p>)}
        </div>
      )}

      {credentials.length > 0 && (
        <div class="cred-row fade" aria-label="Credentials">
          {credentials.map((c: string) => (
            <span class="cred-badge cb-m">{c}</span>
          ))}
        </div>
      )}

      {tags.length > 0 && (
        <div class="cred-row fade" aria-label="Topics">
          {tags.map((tag: string) => (
            <span class="cred-badge cb-m">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <aside class="sp fade" aria-label="Find me elsewhere">
      <div class="sp-h">Find me elsewhere</div>

      {links.map((link: ProfileLink) => (
        <a class="si" href={link.href} target="_blank" rel="noopener noreferrer">
          <div class="sl2">
            <span class="su">{link.label}</span>
          </div>
          <span class="sa" aria-hidden="true">→</span>
        </a>
      ))}

      {contact.map((item: ProfileContact) => (
        <a class="si" href={item.href} target="_blank" rel="noopener noreferrer">
          <div class="sl2">
            <span class="su">{item.label}</span>
          </div>
          <span class="sa" aria-hidden="true">→</span>
        </a>
      ))}
    </aside>
  </div>
</section>
