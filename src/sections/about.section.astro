---
import { getCollection } from "../lib/api";

const profile = await getCollection<any>("profile");

const headline = profile?.headline ?? "";
const biography = profile?.biography ?? "";
const credentials = Array.isArray(profile?.summary) ? profile.summary : [];
const links = Array.isArray(profile?.portfolioLinks) ? profile.portfolioLinks : [];
const contact = Array.isArray(profile?.contact) ? profile.contact : [];
---

<section id="about">
  <p class="sl">About</p>

  <div class="about-grid">
    <div>
      <h3 class="ah fade">
        {profile?.name ?? ""}<br />
        <em>{headline}</em>
      </h3>

      <div class="ab fade">
        {biography}
      </div>

      <div class="cred-row fade">
        {credentials.map((c) => (
          <span class="cred-badge cb-m">{c}</span>
        ))}
      </div>
    </div>

    <div class="sp fade">
      <div class="sp-h">Find me elsewhere</div>

      {links.map((link) => (
        <a class="si" href={link.href} target="_blank" rel="noopener noreferrer">
          <div class="sl2">
            <span class="su">{link.label}</span>
          </div>
          <span class="sa">→</span>
        </a>
      ))}

      {contact.map((item) => (
        <a class="si" href={item.href} target="_blank" rel="noopener noreferrer">
          <div class="sl2">
            <span class="su">{item.label}</span>
          </div>
          <span class="sa">→</span>
        </a>
      ))}
    </div>
  </div>
</section>
