+
+.breadcrumb{max-width:78rem;margin:0 auto 0.5rem}
+.breadcrumb ol{display:flex;flex-wrap:wrap;list-style:none;gap:.35rem;font-size:.8rem;color:var(--m)}
+.breadcrumb li:not(:last-child)::after{content:"/";margin-left:.35rem;color:var(--bm)}
+.breadcrumb a{color:var(--m);text-decoration:none}
+.breadcrumb a:hover,.breadcrumb a:focus-visible{color:var(--teal);text-decoration:underline}
+.breadcrumb li[aria-current="page"]{color:var(--w);max-width:32ch;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
+
+.project-layout{display:grid;gap:2.5rem;grid-template-columns:1fr;align-items:start}
+.project-sidebar{display:grid;gap:1.5rem;order:2}
+.project-content{order:1;min-width:0}
+.project-body{font-size:1rem;line-height:1.75;color:var(--w)}
+.project-body h2{font-family:var(--font-display);margin-top:2.25rem;margin-bottom:.75rem}
+.project-body p{margin-bottom:1.1rem;color:var(--mb)}
+.project-body img{max-width:100%;border-radius:.9rem}
+
+.sidebar-block{padding:1.25rem 1.4rem;border:1px solid var(--bd);border-radius:1rem;background:var(--card)}
+.sidebar-block h2{font-family:var(--font-display);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--m);margin-bottom:.85rem}
+.sidebar-block p{font-size:.9rem;color:var(--w);line-height:1.6}
+
+.chip-list,.bullet-list,.link-list{list-style:none;display:flex;flex-wrap:wrap;gap:.5rem;margin:0;padding:0}
+.bullet-list{flex-direction:column;gap:.5rem}
+.bullet-list li{font-size:.88rem;color:var(--mb);padding-left:1rem;position:relative}
+.bullet-list li::before{content:"–";position:absolute;left:0;color:var(--teal)}
+.chip-list li a,.chip-list li{font-family:var(--font-display);font-size:.72rem;font-weight:600;letter-spacing:.04em;text-transform:capitalize;border:1px solid var(--bm);color:var(--mb);padding:.28rem .65rem;border-radius:999px;text-decoration:none;display:inline-block;transition:color .15s,border-color .15s}
+.chip-list li a:hover,.chip-list li a:focus-visible{color:var(--teal);border-color:var(--teal)}
+.link-list{flex-direction:column;gap:.6rem}
