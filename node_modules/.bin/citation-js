#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/citation-js@0.8.1/node_modules/citation-js/bin/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/citation-js@0.8.1/node_modules/citation-js/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/citation-js@0.8.1/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/citation-js@0.8.1/node_modules/citation-js/bin/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/citation-js@0.8.1/node_modules/citation-js/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/citation-js@0.8.1/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/citation-js@0.8.1/node_modules/citation-js/bin/cmd.js" "$@"
else
  exec node  "$basedir/../.pnpm/citation-js@0.8.1/node_modules/citation-js/bin/cmd.js" "$@"
fi
