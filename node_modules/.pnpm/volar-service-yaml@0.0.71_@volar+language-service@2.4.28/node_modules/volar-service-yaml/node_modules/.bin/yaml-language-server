#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/yaml-language-server@1.23.0/node_modules/yaml-language-server/bin/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/yaml-language-server@1.23.0/node_modules/yaml-language-server/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/yaml-language-server@1.23.0/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/yaml-language-server@1.23.0/node_modules/yaml-language-server/bin/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/yaml-language-server@1.23.0/node_modules/yaml-language-server/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/yaml-language-server@1.23.0/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../yaml-language-server@1.23.0/node_modules/yaml-language-server/bin/yaml-language-server" "$@"
else
  exec node  "$basedir/../../../../../yaml-language-server@1.23.0/node_modules/yaml-language-server/bin/yaml-language-server" "$@"
fi
