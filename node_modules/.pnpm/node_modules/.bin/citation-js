else
  export NODE_PATH="/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/@citation-js+cli@0.8.1/node_modules/@citation-js/cli/lib/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/@citation-js+cli@0.8.1/node_modules/@citation-js/cli/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/@citation-js+cli@0.8.1/node_modules/@citation-js/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/@citation-js+cli@0.8.1/node_modules:/Volumes/DevProjects/rjmlaird/rjmlaird.co.uk/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@citation-js/cli/lib/index.js" "$@"
else
  exec node  "$basedir/../@citation-js/cli/lib/index.js" "$@"
fi
