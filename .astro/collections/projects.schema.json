{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "number"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "author": {
      "type": "string"
    },
    "tag": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": "string"
    },
    "imageCredit": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "tools_tech": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "github": {
          "type": "string",
          "format": "uri"
        },
        "live": {
          "type": "string",
          "format": "uri"
        },
        "demo": {
          "type": "string",
          "format": "uri"
        },
        "docs": {
          "type": "string",
          "format": "uri"
        },
        "video": {
          "type": "string",
          "format": "uri"
        },
        "store": {
          "type": "string",
          "format": "uri"
        },
        "api": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "impact": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "date"
  ]
}